@model FoodOrderingWeb.Models.User
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header text-white text-center py-3" style="background-color: #10b981;">
                    <h5 class="fw-bold mb-0 text-uppercase">Khôi phục mật khẩu</h5>
                </div>x
                <div class="card-body p-4 text-center">

                    <p class="text-muted small mb-4">
                        Nhập Email đã đăng ký để nhận mật khẩu mới.
                    </p>

                    @* Form đã được thêm ID để xử lý AJAX *@
                    <form id="forgotPassForm" asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="form-floating mb-4">
                            <input type="email" name="email" class="form-control rounded-3 bg-light border-0" id="floatEmail" placeholder="Email" required>
                            <label for="floatEmail">Email của bạn</label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" id="btnSubmit" class="btn btn-success fw-bold text-white rounded-pill shadow-sm" style="background-color: #10b981; border: none;">
                                GỬI YÊU CẦU
                            </button>
                            <a asp-action="Login" class="btn btn-light fw-bold text-muted rounded-pill border mt-2">
                                Quay lại Đăng nhập
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* Nhúng thư viện SweetAlert2 *@
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // Xử lý gửi form bằng AJAX
            $('#forgotPassForm').on('submit', function (e) {
                e.preventDefault(); // Chặn việc load lại trang

                const btn = $('#btnSubmit');
                const originalText = btn.text();

                // Hiệu ứng đang xử lý
                btn.prop('disabled', true).text('ĐANG XỬ LÝ...');

                $.ajax({
                    url: $(this).attr('action'),
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (res) {
                        if (res.success) {
                            // THÔNG BÁO THÀNH CÔNG: Tự mất sau 1.5 giây
                            Swal.fire({
                                title: 'Thành công',
                                text: res.message || 'Yêu cầu đã được gửi! Vui lòng kiểm tra email.',
                                icon: 'success',
                                timer: 1500,
                                showConfirmButton: false,
                                position: 'center'
                            }).then(() => {
                                // Sau khi ẩn thông báo, chuyển về trang đăng nhập
                                window.location.href = '@Url.Action("Login", "Account")';
                            });
                        } else {
                            // THÔNG BÁO LỖI (Ví dụ: Email không tồn tại)
                            Swal.fire({
                                title: 'Lỗi!',
                                text: res.message || 'Email này không tồn tại trên hệ thống!',
                                icon: 'error',
                                confirmButtonColor: '#10b981'
                            });
                            btn.prop('disabled', false).text(originalText);
                        }
                    },
                    error: function () {
                        Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ!', 'error');
                        btn.prop('disabled', false).text(originalText);
                    }
                });
            });
        });
    </script>
}