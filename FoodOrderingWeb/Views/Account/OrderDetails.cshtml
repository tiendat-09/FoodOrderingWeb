@model FoodOrderingWeb.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.OrderId;

    int step = 0;
    string statusText = "";
    string statusClass = "";

    // Đã đồng bộ với StoreManagerController và DriverController
    if (Model.Status == "Pending" || Model.Status == "Chờ xử lý") { step = 1; statusText = "Đang chờ quán nhận"; statusClass = "bg-warning"; }
    else if (Model.Status == "Preparing" || Model.Status == "Processing") { step = 2; statusText = "Quán đang chuẩn bị"; statusClass = "bg-info"; }
    else if (Model.Status == "Shipping" || Model.Status == "Delivering") { step = 3; statusText = "Tài xế đang giao"; statusClass = "bg-primary"; }
    else if (Model.Status == "Completed") { step = 4; statusText = "Giao thành công"; statusClass = "bg-success"; }
    else if (Model.Status != null && Model.Status.Contains("từ chối")) { step = 0; statusText = "Đã hủy/Từ chối"; statusClass = "bg-danger"; }
}

<style>
    .timeline-wrapper {
        display: flex;
        justify-content: space-between;
        position: relative;
        margin: 2rem 0;
    }

        .timeline-wrapper::before {
            content: '';
            position: absolute;
            top: 15px;
            left: 0;
            right: 0;
            height: 3px;
            background: #e9ecef;
            z-index: 0;
        }

    .timeline-item {
        position: relative;
        z-index: 1;
        text-align: center;
        flex: 1;
    }

    .timeline-dot {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        background: #e9ecef;
        margin: 0 auto 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        transition: all 0.3s;
    }

        .timeline-dot.active {
            background: #10b981;
            box-shadow: 0 0 0 5px rgba(16, 185, 129, 0.2);
        }

    .timeline-text {
        font-size: 0.85rem;
        font-weight: 600;
        color: #6c757d;
    }

    .timeline-item.active .timeline-text {
        color: #10b981;
    }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Chi tiết đơn hàng</h2>
            <p class="text-muted mb-0">Mã đơn: #@Model.OrderId <span class="mx-2">|</span> Ngày đặt: @(Model.OrderDate.HasValue ? Model.OrderDate.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")</p>
        </div>
        <a asp-action="OrderHistory" class="btn btn-outline-dark rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Trạng thái đơn hàng</h5>

                    @if (step == 0)
                    {
                        <div class="alert alert-danger rounded-3 fw-bold text-center">
                            <i class="bi bi-x-circle-fill me-2"></i> Đơn hàng này đã bị hủy
                        </div>
                    }
                    else
                    {
                        <div class="timeline-wrapper">
                            <div class="timeline-item @(step >= 1 ? "active" : "")">
                                <div class="timeline-dot @(step >= 1 ? "active" : "")"><i class="bi bi-receipt"></i></div>
                                <div class="timeline-text">Đã đặt hàng</div>
                                <small class="text-muted d-block mt-1">@(Model.OrderDate.HasValue ? Model.OrderDate.Value.ToString("HH:mm") : "")</small>
                            </div>
                            <div class="timeline-item @(step >= 2 ? "active" : "")">
                                <div class="timeline-dot @(step >= 2 ? "active" : "")"><i class="bi bi-box-seam"></i></div>
                                <div class="timeline-text">Đang chuẩn bị</div>
                            </div>
                            <div class="timeline-item @(step >= 3 ? "active" : "")">
                                <div class="timeline-dot @(step >= 3 ? "active" : "")"><i class="bi bi-truck"></i></div>
                                <div class="timeline-text">Đang giao</div>
                            </div>
                            <div class="timeline-item @(step >= 4 ? "active" : "")">
                                <div class="timeline-dot @(step >= 4 ? "active" : "")"><i class="bi bi-check-lg"></i></div>
                                <div class="timeline-text">Hoàn thành</div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold">Danh sách món ăn</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <tbody>
                                @foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td class="ps-4" width="70">
                                            <img src="~/images/@item.Food.ImageUrl" class="rounded-3" width="60" height="60" style="object-fit:cover;">
                                        </td>
                                        <td>
                                            <div class="fw-bold">@item.Food.FoodName</div>
                                        </td>
                                        <td class="text-center">x @item.Quantity</td>
                                        <td class="text-end fw-bold pe-4">@item.Price.ToString("#,##0") ₫</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold">Tổng cộng</span>
                        <span class="fs-4 fw-bold text-primary">@Model.TotalAmount.ToString("#,##0") ₫</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Thông tin nhận hàng</h6>
                    <div class="d-flex mb-3">
                        <div class="me-3 text-secondary"><i class="bi bi-person"></i></div>
                        <div>
                            <small class="text-muted d-block">Người nhận</small>
                            <span class="fw-bold">@Model.User.FullName</span>
                        </div>
                    </div>
                    <div class="d-flex mb-3">
                        <div class="me-3 text-secondary"><i class="bi bi-telephone"></i></div>
                        <div>
                            <small class="text-muted d-block">Số điện thoại</small>
                            <span class="fw-bold">@Model.PhoneNumber</span>
                        </div>
                    </div>
                    <div class="d-flex mb-3">
                        <div class="me-3 text-secondary"><i class="bi bi-geo-alt"></i></div>
                        <div>
                            <small class="text-muted d-block">Địa chỉ giao hàng</small>
                            <span>@Model.Address</span>
                        </div>
                    </div>
                    <hr>
                    <div class="d-flex">
                        <div class="me-3 text-secondary"><i class="bi bi-chat-dots"></i></div>
                        <div>
                            <small class="text-muted d-block">Ghi chú đơn hàng</small>
                            <span class="fst-italic">@(string.IsNullOrEmpty(Model.Note) ? "Không có ghi chú" : Model.Note)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>