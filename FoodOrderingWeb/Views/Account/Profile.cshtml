@using Microsoft.AspNetCore.Http
@using Microsoft.EntityFrameworkCore
@inject IHttpContextAccessor HttpContextAccessor
@inject FoodOrderingWeb.Models.FoodOrderingDbContext _context
@model FoodOrderingWeb.Models.User

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool isPendingStore = _context.Stores.Any(s => s.OwnerId == Model.UserId && s.IsActive == false);
}

<style>
    body {
        background: #f8f9fa !important;
    }

    .profile-wrapper {
        display: flex;
        max-width: 1200px; /* Chỉnh từ 1400px xuống 1200px hoặc 1100px để thu hẹp chiều ngang */
        margin: 10px auto; /* Giảm margin để đẩy giao diện lên trên */
        gap: 15px; /* Giảm khoảng cách giữa sidebar và nội dung chính */
        zoom: 0.82;
    }
    /* SIDEBAR TRÁI */
    .profile-sidebar {
        width: 400px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        padding: 0;
        overflow: hidden;
        display: flex; 
        flex-direction: column; 
        align-self: stretch; 
    }

    .sidebar-header {
        background: linear-gradient(135deg, #00d084 0%, #00b96f 100%);
        height: 120px; /* Tăng từ 100px lên 120px để dải xanh trông cân đối hơn */
        position: relative;
    }

    .sidebar-avatar-container {
        position: absolute;
        bottom: -60px; /* Đẩy xuống một nửa so với avatar mới (120/2) */
        left: 50%;
        transform: translateX(-50%);
    }

    .sidebar-avatar-wrapper {
        position: relative;
        width: 120px; /* 🔥 Chỉnh to từ 85px lên 120px */
        height: 120px;
    }

    .sidebar-avatar {
        width: 120px; /* 🔥 Chỉnh to từ 85px lên 120px */
        height: 120px;
        border-radius: 50%;
        border: 5px solid white;
        object-fit: cover;
        background: #f0f0f0;
        box-shadow: 0 4px 8px rgba(0,0,0,0.15);
    }

    .avatar-edit-btn {
        position: absolute;
        bottom: 5px;
        right: 5px;
        width: 35px; /* Nút sửa to lên một chút cho hợp với avatar mới */
        height: 35px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        cursor: pointer;
        transition: 0.3s;
    }

        .avatar-edit-btn:hover {
            transform: scale(1.1);
        }

    .sidebar-content {
        /* 🔥 Tăng padding-top lên 70px để tránh đè vào avatar to,
               đồng thời rút khoảng cách dưới để đẩy form lên */
        padding: 70px 25px 25px 25px;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .sidebar-badge {
        background: #fff;
        border: 1px solid #eee;
        color: #333;
        padding: 6px 18px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 15px; /* 🔥 Giảm từ 25px xuống 15px để kéo Form xích lên gần Avatar hơn */
    }

    .sidebar-form-group {
        margin-bottom: 20px;
    }

        .sidebar-form-group label {
            font-size: 13px;
            font-weight: 600;
            color: #555;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .sidebar-form-group input, .sidebar-form-group textarea {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 14px;
            transition: 0.3s;
        }

            .sidebar-form-group input:focus, .sidebar-form-group textarea:focus {
                outline: none;
                border-color: #00b96f;
                box-shadow: 0 0 0 3px rgba(0,185,111,0.1);
            }

    .sidebar-save-btn {
        width: 100%;
        background: #00b96f;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        font-weight: bold;
        font-size: 14px;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .sidebar-save-btn:hover {
            background: #00a060;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0,185,111,0.3);
        }

        .sidebar-save-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
        }
    /* MODAL CHỌN AVATAR */
    .avatar-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
        animation: fadeIn 0.3s;
    }

        .avatar-modal.show {
            display: flex;
            align-items: center;
            justify-content: center;
        }

    .avatar-modal-content {
        background: white;
        border-radius: 12px;
        padding: 30px;
        max-width: 600px;
        width: 90%;
        max-height: 80vh;
        overflow-y: auto;
        animation: slideUp 0.3s;
    }

    .avatar-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 2px solid #f0f0f0;
    }

        .avatar-modal-header h4 {
            margin: 0;
            font-size: 20px;
            font-weight: bold;
            color: #333;
        }

    .modal-close-btn {
        background: none;
        border: none;
        font-size: 28px;
        cursor: pointer;
        color: #999;
        line-height: 1;
        padding: 0;
        width: 30px;
        height: 30px;
    }

        .modal-close-btn:hover {
            color: #333;
        }

    .avatar-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        gap: 15px;
    }

    .avatar-option {
        position: relative;
        cursor: pointer;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid transparent;
        transition: 0.3s;
    }

        .avatar-option:hover {
            transform: scale(1.05);
            border-color: #00b96f;
        }

        .avatar-option.selected {
            border-color: #00b96f;
            box-shadow: 0 0 0 3px rgba(0,185,111,0.2);
        }

        .avatar-option img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            aspect-ratio: 1/1;
        }

        .avatar-option .check-icon {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: #00b96f;
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .avatar-option.selected .check-icon {
            display: flex;
        }

    .modal-actions {
        margin-top: 25px;
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }

    .modal-btn {
        padding: 10px 25px;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
    }

    .modal-btn-primary {
        background: #00b96f;
        color: white;
    }

        .modal-btn-primary:hover {
            background: #00a060;
        }

    .modal-btn-secondary {
        background: #f0f0f0;
        color: #666;
    }

        .modal-btn-secondary:hover {
            background: #e0e0e0;
        }
    /* MAIN CONTENT PHẢI */
    .profile-main {
        flex: 1;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        padding: 20px 30px;
    }

    .main-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #f0f0f0;
    }

    .main-title {
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .main-title i {
            font-size: 26px;
            color: #333;
        }

        .main-title h3 {
            font-size: 22px;
            font-weight: bold;
            color: #333;
            margin: 0;
        }

    .important-label {
        color: #ff4757;
        font-size: 13px;
        font-weight: 600;
    }

    .security-section {
        margin-bottom: 40px;
    }

    .section-number-title {
        font-size: 16px;
        font-weight: bold;
        color: #333;
        margin-bottom: 20px;
    }

    .form-row {
        display: flex;
        gap: 20px;
        margin-bottom: 15px;
    }

    .form-col {
        flex: 1;
    }

    .form-field {
        margin-bottom: 15px;
    }

        .form-field label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #666;
            margin-bottom: 8px;
        }

        .form-field input, .form-field textarea {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #e0e0e0;
            border-radius: 6px;
            font-size: 14px;
            transition: 0.3s;
        }

            .form-field input:focus, .form-field textarea:focus {
                outline: none;
                border-color: #333;
                box-shadow: 0 0 0 3px rgba(0,0,0,0.05);
            }

            .form-field input[readonly], .form-field input[disabled] {
                background: #f5f5f5;
                cursor: not-allowed;
            }

    .action-btn {
        padding: 11px 30px;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn-black {
        background: #000;
        color: white;
    }

        .btn-black:hover {
            background: #333;
        }

        .btn-black:disabled {
            background: #999;
            cursor: not-allowed;
        }

    .btn-yellow {
        background: #ffc107;
        color: #000;
        font-weight: bold;
    }

        .btn-yellow:hover {
            background: #ffb300;
        }

        .btn-yellow:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

    hr.divider {
        border: none;
        border-top: 1px solid #e0e0e0;
        margin: 35px 0;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideUp {
        from {
            transform: translateY(50px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @@media (max-width: 968px) {
        .profile-wrapper {
            flex-direction: column;
        }

        .profile-sidebar {
            width: 100%;
        }

        .avatar-grid {
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
        }
    }

    /* ── PENDING STORE CARD ── */
    .pending-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        overflow: hidden;
        margin-top: 20px;
    }

    .pending-card-header {
        padding: 18px 28px;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .pending-card-header h5 {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #333;
        }

        .pending-card-header p {
            margin: 0;
            font-size: .8rem;
            color: #999;
        }

    .pending-card-body {
        padding: 24px 28px;
    }

    /* progress steps */
    .steps {
        display: flex;
        align-items: flex-start;
        margin-bottom: 22px;
    }

    .step {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
    }

    .step-circle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: .85rem;
    }

        .step-circle.done {
            background: #22c55e;
            color: white;
        }

        .step-circle.active {
            background: #fbbf24;
            color: #7c2d12;
        }

        .step-circle.wait {
            background: #e5e7eb;
            color: #9ca3af;
        }

    .step-line {
        flex: 1;
        height: 3px;
        margin-top: 19px;
        background: #e5e7eb;
    }

        .step-line.done {
            background: #22c55e;
        }

    .step-label {
        font-size: .73rem;
        font-weight: 600;
        margin-top: 7px;
        text-align: center;
        color: #9ca3af;
    }

        .step-label.done {
            color: #16a34a;
        }

        .step-label.active {
            color: #92400e;
        }

    /* info box inside pending card */
    .pending-info-box {
        background: #fffbeb;
        border: 1.5px solid #fcd34d;
        border-radius: 10px;
        padding: 16px 18px;
        display: flex;
        gap: 14px;
        align-items: flex-start;
    }

        .pending-info-box .pi-icon {
            width: 36px;
            height: 36px;
            background: #fbbf24;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 1rem;
        }

        .pending-info-box .pi-text h6 {
            margin: 0 0 4px;
            font-size: .9rem;
            font-weight: 700;
            color: #92400e;
        }

        .pending-info-box .pi-text p {
            margin: 0;
            font-size: .82rem;
            color: #a16207;
            line-height: 1.5;
        }

    /* SUCCESS MODAL */
    @@keyframes modalFadeIn {
        from {
            opacity: 0
        }

        to {
            opacity: 1
        }
    }

    @@keyframes modalPopIn {
        from {
            transform: scale(.88) translateY(20px);
            opacity: 0
        }

        to {
            transform: scale(1) translateY(0);
            opacity: 1
        }
    }

    @@keyframes dotPulse {
        0%, 100% {
            transform: scale(1);
            opacity: 1
        }

        50% {
            transform: scale(1.5);
            opacity: .5
        }
    }
</style>

<div class="profile-wrapper">
    <div class="profile-sidebar">
        <div class="sidebar-header">
            <div class="sidebar-avatar-container">
                <div class="sidebar-avatar-wrapper">
                    <img src="@(string.IsNullOrEmpty(Model.Avatar) ? "/images/avatars/avt4.jpg" : Model.Avatar)"
                         class="sidebar-avatar"
                         id="currentAvatar"
                         onerror="this.src='/images/avatars/avt4.jpg'" />
                    <div class="avatar-edit-btn" onclick="openAvatarModal()">
                        <i class="bi bi-pencil-fill" style="color: #00b96f; font-size: 13px;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="sidebar-content">
            <div class="text-center mb-3">
                <span class="sidebar-badge" style="background-color: transparent; border: none;">
                    @if (Model.Role == "StoreOwner")
                    {
                        <span class="badge bg-success rounded-pill px-3 py-2">⭐ Quản Trị Viên VIP</span>
                    }
                    else if (Model.Role == "Admin")
                    {
                        <span class="badge bg-primary rounded-pill px-3 py-2">👑 Admin VIP</span>
                    }
                    else
                    {
                        @if (isPendingStore)
                        {
                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2 border border-warning shadow-sm">
                                <i class="bi bi-hourglass-split"></i> Hồ sơ chờ duyệt
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary rounded-pill px-3 py-2">Khách Hàng</span>
                        }
                    }
                </span>
            </div>

            <form id="profileForm" autocomplete="off">
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" id="selectedAvatarPath" name="selectedAvatar" value="@Model.Avatar" />

                <div class="sidebar-form-group">
                    <label><i class="bi bi-person-fill"></i> Tên hiển thị</label>
                    <input asp-for="FullName" id="fullNameInput" placeholder="Nhập tên của bạn" autocomplete="off" />
                </div>
                <div class="sidebar-form-group">
                    <label><i class="bi bi-telephone-fill"></i> Số điện thoại</label>
                    <input asp-for="PhoneNumber" placeholder="Nhập số điện thoại" autocomplete="off" />
                </div>
                <div class="sidebar-form-group">
                    <label><i class="bi bi-geo-alt-fill"></i> Địa chỉ</label>
                    <textarea asp-for="Address" rows="3" placeholder="Nhập địa chỉ của bạn..."></textarea>
                </div>

                <button type="submit" class="sidebar-save-btn" id="btnSaveProfile">
                    <i class="bi bi-check-circle-fill"></i> <span>LƯU CẬP NHẬT</span>
                </button>
            </form>
        </div>
    </div>

    <div class="profile-main">
        <div class="main-header">
            <div class="main-title">
                <i class="bi bi-shield-lock-fill"></i> <h3>Bảo mật tài khoản</h3>
            </div>
            <span class="important-label">⚠️ Khu vực quan trọng</span>
        </div>

        <div class="security-section">
            <div class="section-number-title">1. Thay đổi Email đăng nhập</div>
            <form id="changeEmailForm" autocomplete="off">
                <div class="form-row">
                    <div class="form-col">
                        <div class="form-field">
                            <label>Email mới</label>
                            <input type="email" name="NewEmail" placeholder="Nhập email mới..." autocomplete="new-email" required />
                        </div>
                    </div>
                    <div class="form-col">
                        <div class="form-field">
                            <label>Mật khẩu xác nhận</label>
                            <input type="password" name="PasswordConfirm" placeholder="Nhập mật khẩu để xác nhận" autocomplete="new-password" required />
                        </div>
                    </div>
                </div>
                <button type="submit" class="action-btn btn-black" id="btnChangeEmail">Đổi Email</button>
            </form>
        </div>

        <hr class="divider" />

        <div class="security-section">
            <div class="section-number-title">2. Đổi mật khẩu</div>
            <form id="changePasswordForm" autocomplete="off">
                <div class="form-field" style="max-width: 400px;">
                    <label>Mật khẩu hiện tại</label>
                    <input type="password" name="CurrentPassword" placeholder="Nhập mật khẩu hiện tại..." autocomplete="new-password" required />
                </div>
                <div class="form-row">
                    <div class="form-col">
                        <div class="form-field">
                            <label>Mật khẩu mới</label>
                            <input type="password" name="NewPassword" placeholder="Nhập mật khẩu mới..." autocomplete="new-password" required />
                        </div>
                    </div>
                    <div class="form-col">
                        <div class="form-field">
                            <label>Nhập lại mật khẩu mới</label>
                            <input type="password" name="ConfirmNewPassword" placeholder="Xác nhận mật khẩu mới..." autocomplete="new-password" required />
                        </div>
                    </div>
                </div>
                <button type="submit" class="action-btn btn-yellow" id="btnChangePassword">Cập nhật mật khẩu</button>
            </form>
        </div>

        @* ── PHẦN CHỜ DUYỆT (hiện bên dưới bảo mật nếu có hồ sơ đang chờ) ── *@
        @if (isPendingStore)
        {
            <hr class="divider" />

            <div class="pending-card">
                <div class="pending-card-header">
                    <i class="bi bi-clock-history text-warning fs-4"></i>
                    <div>
                        <h5>Đăng ký đối tác bán hàng</h5>
                        <p>Trạng thái xét duyệt hồ sơ quán của bạn</p>
                    </div>
                </div>

                <div class="pending-card-body">
                    <div class="steps">
                        <div class="step">
                            <div class="step-circle done">✓</div>
                            <span class="step-label done">Nộp hồ sơ</span>
                        </div>
                        <div class="step-line done"></div>
                        <div class="step">
                            <div class="step-circle active">⏳</div>
                            <span class="step-label active">Chờ duyệt</span>
                        </div>
                        <div class="step-line"></div>
                        <div class="step">
                            <div class="step-circle wait">3</div>
                            <span class="step-label wait">Được duyệt</span>
                        </div>
                        <div class="step-line"></div>
                        <div class="step">
                            <div class="step-circle wait">4</div>
                            <span class="step-label wait">Mở bán</span>
                        </div>
                    </div>

                    <div class="pending-info-box">
                        <div class="pi-icon">⏰</div>
                        <div class="pi-text">
                            <h6>Hồ sơ đang được xem xét</h6>
                            <p>
                                Đội ngũ <strong>OrderFood</strong> đang kiểm tra thông tin quán của bạn.
                                Thời gian xét duyệt thường từ <strong>1–2 ngày làm việc</strong>.
                                Bạn sẽ nhận được thông báo khi có kết quả.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="avatar-modal" id="avatarModal">
    <div class="avatar-modal-content">
        <div class="avatar-modal-header">
            <h4>Chọn ảnh đại diện</h4>
            <button class="modal-close-btn" onclick="closeAvatarModal()">&times;</button>
        </div>
        <div class="avatar-grid" id="avatarGrid">
            @for (int i = 1; i <= 20; i++)
            {
                <div class="avatar-option" data-avatar="/images/avatars/avt@(i).jpg" onclick="selectAvatar(this)">
                    <img src="/images/avatars/avt@(i).jpg" onerror="this.parentElement.style.display='none'" />
                    <div class="check-icon"><i class="bi bi-check-lg"></i></div>
                </div>
            }
        </div>
        <div class="modal-actions">
            <button class="modal-btn modal-btn-secondary" onclick="closeAvatarModal()">Hủy</button>
            <button class="modal-btn modal-btn-primary" onclick="confirmAvatarSelection()">Xác nhận</button>
        </div>
    </div>
</div>

@* ── MODAL ĐĂNG KÝ THÀNH CÔNG (hiện ngay khi redirect về Profile sau RegisterStore) ── *@
@if (TempData["SuccessMessage"] != null)
{
    <div id="successOverlay" style="
        position:fixed; inset:0; z-index:10000;
        background:rgba(0,0,0,.52);
        backdrop-filter:blur(4px);
        display:flex; align-items:center; justify-content:center;
        animation: modalFadeIn .25s ease;">

        <div style="
            background:#fff; border-radius:16px;
            padding:48px 40px 40px; max-width:460px; width:90%;
            text-align:center;
            box-shadow:0 20px 60px rgba(0,0,0,.22);
            animation: modalPopIn .35s cubic-bezier(.34,1.56,.64,1);">

            <div style="width:80px;height:80px;border-radius:50%;
                background:#dcfce7;margin:0 auto 22px;
                display:flex;align-items:center;justify-content:center;">
                <svg width="42" height="42" viewBox="0 0 24 24"
                     fill="none" stroke="#16a34a" stroke-width="3"
                     stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12" />
                </svg>
            </div>

            <h4 style="font-size:1.4rem;font-weight:800;color:#15803d;margin-bottom:10px;">
                Đăng ký thành công! 🎉
            </h4>
            <p style="color:#555;font-size:.95rem;line-height:1.65;margin-bottom:22px;">
                @TempData["SuccessMessage"]
            </p>

            <div style="display:inline-flex;align-items:center;gap:8px;
                background:#fef9c3;border:1.5px solid #fbbf24;
                border-radius:999px;padding:7px 20px;
                font-size:.85rem;font-weight:700;color:#92400e;
                margin-bottom:28px;">
                <span style="width:9px;height:9px;border-radius:50%;
                    background:#f59e0b;display:inline-block;
                    animation:dotPulse 1.4s ease-in-out infinite;"></span>
                Đang chờ Admin xét duyệt
            </div>

            <br />
            <button onclick="document.getElementById('successOverlay').style.display='none'"
                    style="display:inline-block;padding:13px 36px;border-radius:10px;
                background:#22c55e;color:#fff;font-weight:700;font-size:1rem;
                border:none;cursor:pointer;transition:background .15s;"
                    onmouseover="this.style.background='#16a34a'"
                    onmouseout="this.style.background='#22c55e'">
                Đã hiểu, đóng lại
            </button>
            <p style="margin-top:16px;font-size:.8rem;color:#aaa;">
                Thời gian xét duyệt thường từ 1–2 ngày làm việc.
            </p>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let selectedAvatarUrl = '@Model.Avatar';

        function openAvatarModal() {
            document.getElementById('avatarModal').classList.add('show');
            document.body.style.overflow = 'hidden';
        }
        function closeAvatarModal() {
            document.getElementById('avatarModal').classList.remove('show');
            document.body.style.overflow = 'auto';
        }
        function selectAvatar(element) {
            document.querySelectorAll('.avatar-option').forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');
            selectedAvatarUrl = element.getAttribute('data-avatar');
        }
        function confirmAvatarSelection() {
            if (selectedAvatarUrl) {
                document.getElementById('currentAvatar').src = selectedAvatarUrl + '?v=' + new Date().getTime();
                document.getElementById('selectedAvatarPath').value = selectedAvatarUrl;
                closeAvatarModal();
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const currentAvatarSrc = '@Model.Avatar';
            document.querySelectorAll('.avatar-option').forEach(el => {
                if (el.getAttribute('data-avatar') === currentAvatarSrc) el.classList.add('selected');
            });
        });

        document.getElementById('avatarModal').addEventListener('click', function (e) {
            if (e.target === this) closeAvatarModal();
        });

        // AJAX SUBMIT FORMS
        $('#profileForm').on('submit', function (e) {
            e.preventDefault();
            var btn = $('#btnSaveProfile');
            btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Đang lưu...');
            var formData = {
                UserId: $('input[name="UserId"]').val(),
                FullName: $('input[name="FullName"]').val(),
                PhoneNumber: $('input[name="PhoneNumber"]').val(),
                Address: $('textarea[name="Address"]').val(),
                selectedAvatar: $('#selectedAvatarPath').val()
            };
            $.ajax({
                url: '/Account/UpdateProfile', type: 'POST', data: formData,
                success: function (response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công',
                            text: response.message,
                            timer: 1500,
                            showConfirmButton: false
                        });
                        $('#headerFullName').text(formData.FullName);
                        if (formData.selectedAvatar) $('#headerAvatarImg').attr('src', formData.selectedAvatar + '?v=' + new Date().getTime());
                    } else {
                        Swal.fire('Thất bại', response.message, 'error');
                    }
                },
                error: function () {
                    Swal.fire('Lỗi', 'Có lỗi xảy ra!', 'error');
                },
                complete: function () {
                    btn.prop('disabled', false).html('<i class="bi bi-check-circle-fill"></i> <span>LƯU CẬP NHẬT</span>');
                }
            });
        });

        $('#changeEmailForm').on('submit', function (e) {
            e.preventDefault();
            var btn = $('#btnChangeEmail');
            btn.prop('disabled', true).text('Đang xử lý...');
            $.ajax({
                url: '/Account/ChangeEmail', type: 'POST', data: $(this).serialize(),
                success: function (response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công',
                            text: response.message,
                            timer: 1500,
                            showConfirmButton: false
                        });
                        $('#changeEmailForm')[0].reset();
                    } else {
                        Swal.fire('Thất bại', response.message, 'error');
                    }
                },
                error: function () {
                    Swal.fire('Lỗi', 'Có lỗi xảy ra!', 'error');
                },
                complete: function () {
                    btn.prop('disabled', false).text('Đổi Email');
                }
            });
        });

        $('#changePasswordForm').on('submit', function (e) {
            e.preventDefault();
            var btn = $('#btnChangePassword');
            btn.prop('disabled', true).text('Đang xử lý...');
            $.ajax({
                url: '/Account/ChangePassword', type: 'POST', data: $(this).serialize(),
                success: function (response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công',
                            text: response.message,
                            timer: 1500,
                            showConfirmButton: false
                        });
                        $('#changePasswordForm')[0].reset();
                    } else {
                        Swal.fire('Thất bại', response.message, 'error');
                    }
                },
                error: function () {
                    Swal.fire('Lỗi', 'Có lỗi xảy ra!', 'error');
                },
                complete: function () {
                    btn.prop('disabled', false).text('Cập nhật mật khẩu');
                }
            });
        });
    </script>
}