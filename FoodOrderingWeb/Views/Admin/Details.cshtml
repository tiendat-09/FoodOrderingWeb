@model FoodOrderingWeb.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.OrderId;
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Chi Tiết Đơn Hàng #@Model.OrderId</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Thông tin khách hàng</h5>
                </div>
                <div class="card-body">
                    <p><strong>Khách hàng:</strong> @Model.User?.FullName (@Model.User?.Username)</p>
                    <p><strong>SĐT:</strong> @(Model.PhoneNumber ?? "Không có")</p>
                    <p><strong>Địa chỉ:</strong> @(Model.Address ?? "Tại quán")</p>
                    <p><strong>Ngày đặt:</strong> @((Model.OrderDate ?? DateTime.Now).ToString("dd/MM/yyyy HH:mm"))</p>
                    <p><strong>Ghi chú:</strong> <em class="text-muted">@(Model.Note ?? "Không có")</em></p>
                </div>
            </div>

            <div class="card shadow">
                <div class="card-header bg-info text-dark">
                    <h5 class="mb-0">Trạng thái đơn hàng</h5>
                </div>
                <div class="card-body text-center">
                    <h3 class="fw-bold text-primary">@Model.Status</h3>
                    @if (Model.Status == "Pending")
                    {
                        <div class="d-grid gap-2 mt-3">
                            <a asp-action="UpdateStatus" asp-route-id="@Model.OrderId" asp-route-status="Completed"
                               class="btn btn-success">Hoàn thành</a>
                            <a asp-action="UpdateStatus" asp-route-id="@Model.OrderId" asp-route-status="Cancelled"
                               class="btn btn-danger">Hủy đơn</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Món đã đặt</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table align-middle mb-0">
                        <thead class="bg-light">
                            <tr><th>Món ăn</th><th class="text-center">SL</th><th class="text-end">Thành tiền</th></tr>
                        </thead>
                        <tbody>
                            @if (Model.OrderDetails != null)
                            {
                                @foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-bold">@item.Food?.FoodName</div>
                                            <small class="text-muted">@item.Note</small>
                                        </td>
                                        <td class="text-center">x @item.Quantity</td>
                                        <td class="text-end">@((item.Price * item.Quantity).ToString("#,##0")) đ</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot class="bg-light">
                            <tr>
                                <td colspan="2" class="text-end fw-bold">TỔNG CỘNG:</td>
                                <td class="text-end fw-bold text-danger fs-4">
                                    @((Model.TotalAmount ).ToString("#,##0")) đ
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>