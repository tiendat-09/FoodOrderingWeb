@model List<FoodOrderingWeb.Models.Food>

@{
    ViewData["Title"] = "Quản lý món ăn";
}

<div class="container-fluid py-4" style="background-color: #f8f9fa; min-height: 100vh;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark mb-0">Quản lý Món ăn</h3>
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-white bg-white border shadow-sm rounded-circle position-relative">
                <i class="bi bi-bell"></i>
                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
            </button>
            <div class="d-flex align-items-center gap-2">
                <img src="https://ui-avatars.com/api/?name=Admin+User&background=random" class="rounded-circle" width="40" height="40">
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-md-5">
                    <form action="" method="get">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                            <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="Tìm kiếm món ăn..." value="@Context.Request.Query["search"]">
                        </div>
                    </form>
                </div>

                <div class="col-md-2">
                    <select class="form-select bg-light border-0">
                        <option>Tất cả trạng thái</option>
                        <option>Hoạt động</option>
                        <option>Ngừng bán</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select bg-light border-0">
                        <option>Tất cả danh mục</option>
                        <option>Món chính</option>
                        <option>Đồ uống</option>
                    </select>
                </div>

                <div class="col-md-3 text-end">
                    <a asp-action="CreateFood" class="btn btn-primary w-100 fw-bold shadow-sm" style="background-color: #5c6ac4; border: none;">
                        <i class="bi bi-plus-lg me-1"></i> Thêm món ăn mới
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3" width="50"><input type="checkbox" class="form-check-input"></th>
                            <th width="80">Ảnh</th>
                            <th>Tên món</th>
                            <th>Danh mục</th>
                            <th>Giá</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4"><input type="checkbox" class="form-check-input"></td>
                                <td>
                                    <img src="~/images/@item.ImageUrl" class="rounded-3 border" style="width: 48px; height: 48px; object-fit: cover;">
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.FoodName</div>
                                </td>
                                <td class="text-muted">@item.Category?.CategoryName</td>
                                <td class="fw-bold">@item.Price.ToString("#,##0") ₫</td>
                                <td>
                                    @if (item.IsActive == true)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-2">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3 py-2">Không hoạt động</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="EditFood" asp-route-id="@item.FoodId" class="btn btn-light btn-sm text-secondary border me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="DeleteFood" asp-route-id="@item.FoodId" class="btn btn-light btn-sm text-secondary border" onclick="return confirm('Xóa món này?');">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white border-0 py-3">
            <div class="d-flex justify-content-between align-items-center small text-muted">
                <span>Hiển thị @Model.Count món ăn</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-1">
                        <li class="page-item disabled"><a class="page-link border-0 rounded" href="#"><i class="bi bi-chevron-left"></i></a></li>
                        <li class="page-item active"><a class="page-link border-0 rounded" href="#" style="background-color: #5c6ac4;">1</a></li>
                        <li class="page-item"><a class="page-link border-0 rounded" href="#">2</a></li>
                        <li class="page-item"><a class="page-link border-0 rounded" href="#">3</a></li>
                        <li class="page-item"><a class="page-link border-0 rounded" href="#"><i class="bi bi-chevron-right"></i></a></li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>