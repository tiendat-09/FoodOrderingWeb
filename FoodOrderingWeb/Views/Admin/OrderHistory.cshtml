@model List<FoodOrderingWeb.Models.Order>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container py-5">
    <h2 class="mb-4 fw-bold text-primary">Lịch Sử Đặt Hàng</h2>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">Bạn chưa có đơn hàng nào. <a asp-controller="Home" asp-action="Index">Đặt món ngay!</a></div>
    }
    else
    {
        <div class="card shadow border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Mã đơn</th>
                                <th>Ngày đặt</th>
                                <th>Quán ăn</th>
                                <th>Món ăn</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th class="text-end pe-4">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-muted">#@item.OrderId</td>
                                    <td>@((item.OrderDate ?? DateTime.Now).ToString("dd/MM/yyyy HH:mm"))</td>

                                    <td class="fw-bold text-dark">
                                        <i class="bi bi-shop text-warning"></i> @(item.Store?.StoreName ?? "N/A")
                                    </td>

                                    <td>
                                        @if (item.OrderDetails != null && item.OrderDetails.Any())
                                        {
                                            <ul class="list-unstyled mb-0 small">
                                                @foreach (var d in item.OrderDetails)
                                                {
                                                    <li>- @d.Food?.FoodName <span class="text-muted">(x@(d.Quantity))</span></li>
                                                }
                                            </ul>
                                        }
                                    </td>

                                    <td class="fw-bold text-primary">@((item.TotalAmount).ToString("#,##0")) đ</td>

                                    <td>
                                        @{
                                            string statusVN = item.Status switch { "Pending" => "Chờ xử lý", "Preparing" => "Quán đang chuẩn bị", "Shipping" => "Tài xế đang đến quán", "Arrived" => "Tài xế chờ lấy món", "Delivering" => "Đang giao hàng", "Completed" => "Đã giao thành công", "Cancelled" => "Đã hủy", _ => item.Status };
                                            string badgeClass = item.Status switch { "Completed" => "bg-success", "Cancelled" => "bg-danger", "Pending" => "bg-warning text-dark", _ => "bg-primary" };
                                        }
                                        <span class="badge @badgeClass px-3 py-2">@statusVN</span>
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="d-flex flex-column align-items-end gap-1">

                                            @if (item.Status != "Completed" && item.Status != "Cancelled" && !(item.Status != null && item.Status.Contains("Đã từ chối")))
                                            {
                                                <a href="/Cart/Tracking/@item.OrderId" class="btn btn-sm btn-outline-primary rounded-pill fw-bold mb-1">
                                                    <i class="bi bi-geo-alt-fill"></i> Theo dõi
                                                </a>
                                            }

                                            @if (item.Status == "Completed")
                                            {
                                                // 1. NÚT ĐÁNH GIÁ TÀI XẾ
                                                if (item.DriverRating == null && item.Driver != null)
                                                {
                                                    <button onclick="openDriverReview(@item.OrderId, '@item.Driver.FullName')" class="btn btn-sm btn-success text-white rounded-pill fw-bold">
                                                        <i class="bi bi-person-badge"></i> Đánh giá Shipper
                                                    </button>
                                                }

                                                // 2. NÚT ĐÁNH GIÁ QUÁN
                                                if (item.StoreRating == null)
                                                {
                                                    <button onclick="openStoreReview(@item.OrderId, '@(item.Store?.StoreName?.Replace("'", "\\'"))')" class="btn btn-sm btn-warning text-dark rounded-pill fw-bold mt-1">
                                                        <i class="bi bi-shop"></i> Đánh giá Quán
                                                    </button>
                                                }

                                                if (item.DriverRating != null && item.StoreRating != null)
                                                {
                                                    <span class="badge bg-light text-success border border-success"><i class="bi bi-check-all"></i> Đã đánh giá</span>
                                                }
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="storeReviewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header bg-warning">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-shop"></i> Đánh giá món ăn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4">
                <h6 class="fw-bold mb-3">Bạn thấy đồ ăn tại <span id="reviewStoreName" class="text-primary"></span> thế nào?</h6>
                <form id="storeReviewForm">
                    <input type="hidden" id="storeReviewOrderId" />
                    <div class="star-rating mb-3" style="display: flex; flex-direction: row-reverse; justify-content: center; gap: 10px;">
                        <input type="radio" id="sstar5" name="srating" value="5" /><label for="sstar5" style="font-size: 40px; color: #ccc; cursor: pointer;">★</label>
                        <input type="radio" id="sstar4" name="srating" value="4" /><label for="sstar4" style="font-size: 40px; color: #ccc; cursor: pointer;">★</label>
                        <input type="radio" id="sstar3" name="srating" value="3" /><label for="sstar3" style="font-size: 40px; color: #ccc; cursor: pointer;">★</label>
                        <input type="radio" id="sstar2" name="srating" value="2" /><label for="sstar2" style="font-size: 40px; color: #ccc; cursor: pointer;">★</label>
                        <input type="radio" id="sstar1" name="srating" value="1" /><label for="sstar1" style="font-size: 40px; color: #ccc; cursor: pointer;">★</label>
                    </div>
                    <style>
                        input[name="srating"] {
                            display: none;
                        }

                            input[name="srating"]:checked ~ label, input[name="srating"]:hover ~ label, label:hover {
                                color: #ffc107 !important;
                            }</style>
                    <textarea id="storeReviewText" class="form-control rounded-3 bg-light" rows="3" placeholder="Đồ ăn ngon không..."></textarea>
                    <button type="button" id="btnSubmitStoreReview" class="btn btn-warning fw-bold w-100 rounded-pill mt-4 py-2">GỬI ĐÁNH GIÁ</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="driverReviewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-person-badge"></i> Đánh giá Shipper</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4">
                <h6 class="fw-bold mb-3">Chuyến đi của tài xế <span id="reviewDriverName" class="text-success"></span> thế nào?</h6>
                <form id="driverReviewForm">
                    <input type="hidden" id="driverReviewOrderId" />
                    <div class="star-rating mb-3" style="display: flex; flex-direction: row-reverse; justify-content: center; gap: 10px;">
                        <input type="radio" id="dstar5" name="drating" value="5" /><label for="dstar5" style="font-size: 40px; color: #ccc; cursor: pointer;">★</label>
                        <input type="radio" id="dstar4" name="drating" value="4" /><label for="dstar4" style="font-size: 40px; color: #ccc; cursor: pointer;">★</label>
                        <input type="radio" id="dstar3" name="drating" value="3" /><label for="dstar3" style="font-size: 40px; color: #ccc; cursor: pointer;">★</label>
                        <input type="radio" id="dstar2" name="drating" value="2" /><label for="dstar2" style="font-size: 40px; color: #ccc; cursor: pointer;">★</label>
                        <input type="radio" id="dstar1" name="drating" value="1" /><label for="dstar1" style="font-size: 40px; color: #ccc; cursor: pointer;">★</label>
                    </div>
                    <style>
                        input[name="drating"] {
                            display: none;
                        }

                            input[name="drating"]:checked ~ label, input[name="drating"]:hover ~ label, label:hover {
                                color: #ffc107 !important;
                            }</style>
                    <textarea id="driverReviewText" class="form-control rounded-3 bg-light" rows="3" placeholder="Shipper thân thiện, giao nhanh..."></textarea>
                    <button type="button" id="btnSubmitDriverReview" class="btn btn-success fw-bold w-100 rounded-pill mt-4 py-2">GỬI ĐÁNH GIÁ TÀI XẾ</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Xử lý Quán
        function openStoreReview(orderId, storeName) {
            $('#storeReviewOrderId').val(orderId);
            $('#reviewStoreName').text(storeName);
            $('#storeReviewForm')[0].reset();
            new bootstrap.Modal(document.getElementById('storeReviewModal')).show();
        }
        $('#btnSubmitStoreReview').click(function () {
            let rating = $('input[name="srating"]:checked').val();
            if (!rating) return Swal.fire('Chú ý', 'Chọn số sao cho quán nhé!', 'warning');
            $.post('/Cart/SubmitStoreReview', { orderId: $('#storeReviewOrderId').val(), rating: rating, review: $('#storeReviewText').val() }, function (res) {
                if (res.success) { Swal.fire('Thành công', 'Đã lưu đánh giá quán.', 'success').then(() => location.reload()); }
            });
        });

        // Xử lý Tài xế
        function openDriverReview(orderId, driverName) {
            $('#driverReviewOrderId').val(orderId);
            $('#reviewDriverName').text(driverName);
            $('#driverReviewForm')[0].reset();
            new bootstrap.Modal(document.getElementById('driverReviewModal')).show();
        }
        $('#btnSubmitDriverReview').click(function () {
            let rating = $('input[name="drating"]:checked').val();
            if (!rating) return Swal.fire('Chú ý', 'Chọn số sao cho tài xế nhé!', 'warning');
            $.post('/Cart/SubmitDriverReview', { orderId: $('#driverReviewOrderId').val(), rating: rating, review: $('#driverReviewText').val() }, function (res) {
                if (res.success) { Swal.fire('Thành công', 'Đã lưu đánh giá tài xế.', 'success').then(() => location.reload()); }
            });
        });
    </script>
}