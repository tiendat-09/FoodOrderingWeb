@model List<FoodOrderingWeb.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container-fluid py-4">
    <h3 class="fw-bold mb-4">Quản lý Đơn hàng</h3>
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">#@item.OrderId</td>
                            <td>
                                <div>@item.User?.FullName</div>
                                <small class="text-muted">@item.PhoneNumber</small>
                            </td>
                            <td>@(item.OrderDate.HasValue ? item.OrderDate.Value.ToString("dd/MM/yyyy HH:mm") : "")</td>
                            <td class="fw-bold text-primary">@string.Format("{0:#,##0}", item.TotalAmount ) ₫</td>
                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                }
                                else if (item.Status == "Shipping")
                                {
                                    <span class="badge bg-info text-dark">Đang giao</span>
                                }
                                else if (item.Status == "Completed")
                                {
                                    <span class="badge bg-success">Hoàn thành</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã hủy</span>
                                }
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-light border dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        Xử lý
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-action="UpdateStatus" asp-route-id="@item.OrderId" asp-route-status="Shipping">🚚 Giao hàng</a></li>
                                        <li><a class="dropdown-item" asp-action="UpdateStatus" asp-route-id="@item.OrderId" asp-route-status="Completed">✅ Hoàn thành</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" asp-action="UpdateStatus" asp-route-id="@item.OrderId" asp-route-status="Cancelled">❌ Hủy đơn</a></li>
                                    </ul>
                                    <a asp-action="OrderDetails" asp-route-id="@item.OrderId" class="btn btn-sm btn-outline-primary ms-1">Chi tiết</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>