@model FoodOrderingWeb.Models.User
@{
    ViewData["Title"] = "Hồ sơ Quản trị viên";
    Layout = "_AdminLayout";
}

<style>
    body {
        background-color: #f4f7f6;
    }

    .card-profile-main {
        border: none;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        background: #fff;
    }

    .profile-avatar-container {
        position: relative;
        width: 130px;
        height: 130px;
        margin: 0 auto 20px;
    }

    .profile-img-circle {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border: 4px solid #fff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .btn-camera-purple {
        position: absolute;
        bottom: 5px;
        right: 5px;
        width: 35px;
        height: 35px;
        background: #6c5ce7;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: 2px solid #fff;
        transition: 0.3s;
    }

    .label-custom {
        font-size: 0.85rem;
        font-weight: 700;
        color: #495057;
        margin-bottom: 8px;
        display: block;
    }

    .input-custom {
        border-radius: 12px;
        border: 1px solid #dee2e6;
        padding: 12px 16px;
        background-color: #fcfcfc;
        width: 100%;
        transition: 0.3s;
    }

        .input-custom:focus {
            border-color: #6c5ce7;
            background-color: #fff;
            box-shadow: none;
            outline: none;
        }

    .btn-purple-main {
        background-color: #6c5ce7;
        border: none;
        color: white;
        padding: 10px 25px;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.3s;
        cursor: pointer;
    }

        .btn-purple-main:hover {
            background-color: #5a4ac7;
            transform: translateY(-2px);
        }

    .btn-pink-main {
        background-color: #ff7675;
        border: none;
        color: white;
        padding: 10px 25px;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-pink-main:hover {
            background-color: #e66767;
            transform: translateY(-2px);
        }

    .avt-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
    }

    .avt-item {
        cursor: pointer;
        border-radius: 15px;
        overflow: hidden;
        border: 3px solid transparent;
        transition: 0.2s;
        height: 80px;
    }

        .avt-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .avt-item.active {
            border-color: #6c5ce7;
            transform: scale(1.05);
        }
</style>

<div class="container-fluid py-4">
    <div class="row g-4">
        @* CỘT TRÁI: HIỂN THỊ TỔNG QUAN *@
        <div class="col-xl-3 col-lg-4">
            <div class="card card-profile-main p-4 text-center">
                <div class="profile-avatar-container">
                    <img src="@(string.IsNullOrEmpty(Model.Avatar) ? "/images/avatars/default_user.jpg" : Model.Avatar)"
                         class="profile-img-circle rounded-circle nav-user-avt" id="imgDisplay" />
                    <div class="btn-camera-purple" onclick="showAvtModal()">
                        <i class="bi bi-camera-fill"></i>
                    </div>
                </div>
                <h4 class="fw-bold mb-1" id="nameDisplay">@Model.FullName</h4>
                <p class="badge bg-light text-primary border px-3 py-2 rounded-pill">Quản Trị Viên</p>

                <div class="text-start mt-4 border-top pt-3">
                    <label class="label-custom">EMAIL ĐĂNG NHẬP</label>
                    <p class="text-muted mb-3" id="emailDisplay">@Model.Email</p>
                    <label class="label-custom">SỐ ĐIỆN THOẠI</label>
                    <p class="text-muted mb-0" id="phoneDisplay">@(Model.PhoneNumber ?? "Chưa cập nhật")</p>
                </div>
            </div>
        </div>

        @* CỘT PHẢI: CÁC FORM CẬP NHẬT *@
        <div class="col-xl-9 col-lg-8">
            @* --- AJAX FORM 1: THÔNG TIN CÁ NHÂN --- *@
            <div class="card card-profile-main p-4 mb-4">
                <h6 class="fw-bold mb-4 text-primary"><i class="bi bi-person-bounding-box me-2"></i>Cập nhật thông tin</h6>
                <form id="profileForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="UserId" value="@Model.UserId" />
                    <input type="hidden" id="inputAvatar" name="Avatar" value="@Model.Avatar" />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="label-custom">Họ và tên</label>
                            <input type="text" name="FullName" class="input-custom" value="@Model.FullName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="label-custom">Số điện thoại</label>
                            <input type="text" name="PhoneNumber" class="input-custom" value="@Model.PhoneNumber">
                        </div>
                        <div class="col-12 text-end">
                            <button type="submit" class="btn btn-purple-main" id="btnSaveInfo">Lưu thay đổi</button>
                        </div>
                    </div>
                </form>
            </div>

            @* --- AJAX FORM 2: BẢO MẬT --- *@
            <div class="card card-profile-main p-4 mb-4">
                <h6 class="fw-bold mb-4 text-danger"><i class="bi bi-shield-lock-fill me-2"></i>Bảo mật tài khoản</h6>

                <p class="fw-bold small mb-3"><i class="bi bi-key-fill me-2"></i>Đổi mật khẩu</p>
                <form id="passForm">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="label-custom">Mật khẩu hiện tại</label>
                            <input type="password" name="CurrentPassword" class="input-custom" required placeholder="••••••••">
                        </div>
                        <div class="col-md-4">
                            <label class="label-custom">Mật khẩu mới</label>
                            <input type="password" name="NewPassword" id="NewPassword" class="input-custom" required placeholder="••••••••">
                        </div>
                        <div class="col-md-4">
                            <label class="label-custom">Nhập lại mật khẩu mới</label>
                            <input type="password" name="ConfirmNewPassword" class="input-custom" required placeholder="••••••••">
                        </div>
                        <div class="col-12 text-end mt-2">
                            <button type="submit" class="btn btn-pink-main">Cập nhật mật khẩu</button>
                        </div>
                    </div>
                </form>

                <hr class="my-4">

                @* --- AJAX FORM 3: ĐỔI EMAIL --- *@
                <p class="fw-bold small mb-3"><i class="bi bi-envelope-fill me-2"></i>Thay đổi Email</p>
                <form id="emailForm">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="label-custom">Email mới</label>
                            <input type="email" name="NewEmail" class="input-custom" required placeholder="example@gmail.com">
                        </div>
                        <div class="col-md-6">
                            <label class="label-custom">Xác nhận mật khẩu</label>
                            <input type="password" name="PasswordConfirm" class="input-custom" required placeholder="••••••••">
                        </div>
                        <div class="col-12 text-end mt-2">
                            <button type="submit" class="btn btn-purple-main">Lưu thay đổi Email</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* MODAL CHỌN AVATAR *@
<div class="modal fade" id="avtModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 p-4 pb-0">
                <h5 class="modal-title fw-bold">Chọn ảnh đại diện</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="avt-grid">
                    @for (int i = 1; i <= 16; i++)
                    {
                        var path = $"/images/avatars/avt{i}.jpg";
                        <div class="avt-item @(Model.Avatar == path ? "active" : "")"
                             onclick="pickAvt(this, '@path')">
                            <img src="@path" />
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer border-0 p-4 pt-0">
                <button type="button" class="btn btn-purple-main w-100 rounded-pill" onclick="applyAvt()">Xác nhận chọn</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Biến tạm lưu ảnh đã chọn trong Modal
        let tempSelectedPath = $('#inputAvatar').val();

        function showAvtModal() {
            new bootstrap.Modal(document.getElementById('avtModal')).show();
        }

        function pickAvt(el, path) {
            $('.avt-item').removeClass('active');
            $(el).addClass('active');
            tempSelectedPath = path;
        }

        function applyAvt() {
            $('#imgDisplay').attr('src', tempSelectedPath);
            $('#inputAvatar').val(tempSelectedPath);
            bootstrap.Modal.getInstance(document.getElementById('avtModal')).hide();
        }

        /* ============================================================
        HÀM DÙNG CHUNG ĐỂ HIỂN THỊ THÔNG BÁO TỰ ĐỘNG MẤT SAU 1.5S
        ============================================================ */
        function notifySuccess(message) {
            Swal.fire({
                title: 'Thành công',
                text: message,
                icon: 'success',
                timer: 1000,               // 1.5 giây
                showConfirmButton: false,  // Ẩn nút OK
                position: 'center'         // Hiện giữa màn hình
            });
        }

        // [AJAX 1]: Cập nhật thông tin cơ bản và Avatar
        $('#profileForm').on('submit', function(e) {
            e.preventDefault();
            const btn = $('#btnSaveInfo');
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Đang lưu...');

            $.ajax({
                url: '/Account/UpdateProfile',
                type: 'POST',
                data: $(this).serialize(),
                success: function(res) {
                    if(res.success) {
                        notifySuccess('Thông tin đã thay đổi!');

                        // Cập nhật UI ngay lập tức không cần F5
                        $('#nameDisplay').text($('input[name="FullName"]').val());
                        $('#phoneDisplay').text($('input[name="PhoneNumber"]').val() || "Chưa cập nhật");
                        $('.nav-user-avt').attr('src', $('#inputAvatar').val());
                    } else {
                        Swal.fire('Thất bại', res.message, 'error');
                    }
                },
                error: function() {
                    Swal.fire('Lỗi', 'Không thể kết nối máy chủ', 'error');
                },
                complete: function() {
                    btn.prop('disabled', false).text('Lưu thay đổi');
                }
            });
        });

        // [AJAX 2]: Đổi mật khẩu
        $('#passForm').on('submit', function(e) {
            e.preventDefault();

            if($('#NewPassword').val() !== $('input[name="ConfirmNewPassword"]').val()) {
                Swal.fire('Lỗi', 'Mật khẩu nhập lại không khớp!', 'error');
                return;
            }

            $.ajax({
                url: '/Account/ChangePassword',
                type: 'POST',
                data: $(this).serialize(),
                success: function(res) {
                    if(res.success) {
                        notifySuccess('Mật khẩu đã được thay đổi!');
                        $('#passForm')[0].reset();
                    } else {
                        Swal.fire('Lỗi', res.message, 'error');
                    }
                }
            });
        });

        // [AJAX 3]: Thay đổi Email
        $('#emailForm').on('submit', function(e) {
            e.preventDefault();

            $.ajax({
                url: '/Account/ChangeEmail',
                type: 'POST',
                data: $(this).serialize(),
                success: function(res) {
                    if(res.success) {
                        notifySuccess('Địa chỉ Email đã được cập nhật!');
                        $('#emailDisplay').text($('input[name="NewEmail"]').val());
                        $('#emailForm')[0].reset();
                    } else {
                        Swal.fire('Lỗi', res.message, 'error');
                    }
                }
            });
        });
    </script>
}