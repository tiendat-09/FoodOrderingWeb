@model List<FoodOrderingWeb.Models.User>
@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "_AdminLayout";
    string currentTab = ViewBag.CurrentTab ?? "Customer";
}

<div class="container-fluid py-4">
    <h4 class="fw-bold mb-4">Quản lý tài khoản</h4>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-0">
            <ul class="nav nav-tabs border-0 px-4 pt-3">
                <li class="nav-item">
                    <a class="nav-link border-0 fw-bold @(currentTab == "Customer" ? "active text-primary border-bottom border-primary border-3" : "text-muted")"
                       href="@Url.Action("Users", new { tab = "Customer" })">Khách hàng</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link border-0 fw-bold @(currentTab == "StoreOwner" ? "active text-primary border-bottom border-primary border-3" : "text-muted")"
                       href="@Url.Action("Users", new { tab = "StoreOwner" })">Chủ quán</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link border-0 fw-bold @(currentTab == "Driver" ? "active text-primary border-bottom border-primary border-3" : "text-muted")"
                       href="@Url.Action("Users", new { tab = "Driver" })">Tài xế</a>
                </li>
            </ul>

            <div class="p-4 border-top">
                <form method="get" action="@Url.Action("Users")" class="row g-3 mb-4">
                    <input type="hidden" name="tab" value="@currentTab" />
                    <div class="col-md-6">
                        <div class="input-group">
                            <input type="text" name="search" class="form-control" placeholder="Tìm kiếm..." value="@ViewBag.Search">
                            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                        </div>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>HỌ TÊN</th>
                                <th>EMAIL</th>
                                <th>SĐT</th>
                                <th class="text-center">HÀNH ĐỘNG</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>#@item.UserId</td>
                                    <td>
                                        <span class="fw-bold">@item.FullName</span>
                                        @if (item.Role == "PendingDriver")
                                        {
                                            <span class="badge bg-warning text-dark ms-2 d-none d-md-inline" title="Đang nộp hồ sơ xin làm tài xế"><i class="bi bi-bicycle"></i> Chờ duyệt</span>
                                        }
                                        else if (item.Role == "PendingStoreOwner")
                                        {
                                            <span class="badge bg-info text-dark ms-2 d-none d-md-inline" title="Đang gửi hồ sơ Chủ quán"><i class="bi bi-shop"></i> Chờ duyệt</span>
                                        }
                                    </td>
                                    <td>@item.Email</td>
                                    <td>@(item.PhoneNumber ?? "---")</td>
                                    <td class="text-center">
                                        @if (item.Role == "Admin")
                                        {
                                            <span class="badge bg-secondary text-white rounded-pill px-3 py-2">
                                                <i class="bi bi-shield-lock me-1"></i> Quản trị viên
                                            </span>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-primary rounded-pill me-2" onclick="openEditModal(@item.UserId)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger rounded-pill" onclick="confirmDelete(@item.UserId)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@* MODAL SỬA USER *@
<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 p-4 pb-0">
                <h5 class="fw-bold mb-0">Chỉnh sửa thành viên</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="editUserForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="editUserId" name="UserId" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">HỌ VÀ TÊN</label>
                        <input type="text" id="editFullName" name="FullName" class="form-control rounded-3" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">SỐ ĐIỆN THOẠI</label>
                        <input type="text" id="editPhoneNumber" name="PhoneNumber" class="form-control rounded-3">
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">VAI TRÒ</label>
                        <select id="editRole" name="Role" class="form-select rounded-3">
                            <option value="Customer">Khách hàng</option>
                            <option value="StoreOwner">Chủ quán</option>
                            <option value="Driver">Tài xế</option>
                        </select>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-light rounded-3" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-3" style="background-color: #6c5ce7; border: none;">Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // HÀM MỞ MODAL SỬA USER
        function openEditModal(id) {
            $.get('/Admin/GetUserJson/' + id, function (res) {
                if (res.success) {
                    $('#editUserId').val(res.data.userId);
                    $('#editFullName').val(res.data.fullName);
                    $('#editPhoneNumber').val(res.data.phoneNumber);
                    $('#editRole').val(res.data.role);
                    new bootstrap.Modal(document.getElementById('editUserModal')).show();
                }
            });
        }

        // HÀM LƯU THAY ĐỔI
        $('#editUserForm').submit(function (e) {
            e.preventDefault();
            let btnSubmit = $(this).find('button[type="submit"]');
            let originalText = btnSubmit.text();
            btnSubmit.prop('disabled', true).text('Đang lưu...');

            $.ajax({
                url: '/Admin/EditUser',
                type: 'POST',
                data: $(this).serialize(),
                success: function (res) {
                    if (res.success) {
                        bootstrap.Modal.getInstance(document.getElementById('editUserModal')).hide();
                        Swal.fire('Thành công', res.message, 'success').then(() => location.reload());
                    } else {
                        Swal.fire('Lỗi', res.message, 'error');
                        btnSubmit.prop('disabled', false).text(originalText);
                    }
                },
                error: function() {
                    Swal.fire('Lỗi', 'Không kết nối được với máy chủ', 'error');
                    btnSubmit.prop('disabled', false).text(originalText);
                }
            });
        });

        // HÀM XÓA VĨNH VIỄN TÀI KHOẢN
        function confirmDelete(id) {
            Swal.fire({
                title: 'Xóa vĩnh viễn?',
                text: "Bạn không thể khôi phục tài khoản này!",
                icon: 'error',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Admin/DeleteUser', { id: id }, function(res) {
                        if (res.success) Swal.fire('Đã xóa!', res.message, 'success').then(() => location.reload());
                        else Swal.fire('Lỗi', res.message, 'error');
                    });
                }
            });
        }
    </script>
}