@model List<FoodOrderingWeb.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h2 class="fw-bold mb-4">Giỏ hàng của bạn</h2>

    @* 🔥 HIỂN THỊ THÔNG BÁO LỖI NẾU TÀI KHOẢN ĐỐI TÁC CỐ TÌNH THANH TOÁN 🔥 *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-4 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                <div>
                    <strong class="d-block">Thông báo từ hệ thống</strong>
                    @TempData["ErrorMessage"]
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <p class="mt-3 text-muted">Giỏ hàng đang trống.</p>
            <a href="/" class="btn btn-success rounded-pill px-4">Đi mua sắm ngay</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Sản phẩm</th>
                                    <th>Đơn giá</th>
                                    <th>Số lượng</th>
                                    <th>Thành tiền</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <img src="@(item.ImageUrl.StartsWith("/") ? item.ImageUrl : "/" + item.ImageUrl)"
                                                     class="rounded me-3 border" style="width: 70px; height: 70px; object-fit: cover;"
                                                     onerror="this.src='/images/foods/default.jpg'">

                                                <div>
                                                    <h6 class="mb-0 fw-bold">
                                                        @item.FoodName
                                                        <a href="javascript:void(0)" class="text-primary ms-2" title="Chỉnh sửa"
                                                           onclick="openEditModal('@item.CartItemId', '@item.FoodName', '@(item.ImageUrl.StartsWith("/") ? item.ImageUrl : "/" + item.ImageUrl)', '@item.Price', '@item.Quantity', '@item.Size', '@item.Note')">
                                                            <i class="bi bi-pencil-square"></i>
                                                        </a>
                                                    </h6>
                                                    <small class="text-muted d-block">Size: @item.Size</small>
                                                    @if (!string.IsNullOrEmpty(item.Note))
                                                    {
                                                        <small class="text-muted d-block fst-italic">Ghi chú: @item.Note</small>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="fw-bold">@item.Price.ToString("N0") đ</td>
                                        <td>
                                            <div class="input-group input-group-sm" style="width: 100px;">
                                                <button class="btn btn-outline-secondary" onclick="updateQty('@item.CartItemId', -1)">-</button>
                                                <input type="text" class="form-control text-center" value="@item.Quantity" id="qty-@item.CartItemId" readonly>
                                                <button class="btn btn-outline-secondary" onclick="updateQty('@item.CartItemId', 1)">+</button>
                                            </div>
                                        </td>
                                        <td class="fw-bold text-success" id="total-@item.CartItemId">@item.TotalPrice.ToString("N0") đ</td>
                                        <td><a href="/Cart/Remove?id=@item.CartItemId" class="text-danger"><i class="bi bi-trash"></i></a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="card border-0 shadow-sm p-4">
                    <h5 class="fw-bold mb-3">Cộng giỏ hàng</h5>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold">Tổng cộng:</span>
                        <span class="fw-bold text-danger fs-5" id="cart-total-price">@Model.Sum(x => x.TotalPrice).ToString("N0") đ</span>
                    </div>

                    <a href="@Url.Action("Checkout", "Cart")" class="btn btn-success w-100 py-3 fw-bold rounded-pill mb-2 shadow-sm">
                        TIẾN HÀNH THANH TOÁN <i class="bi bi-arrow-right ms-2"></i>
                    </a>

                    <a href="/" class="btn btn-outline-secondary w-100 py-2 rounded-pill border-0">
                        <i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@* ... Phần Modal và Script giữ nguyên như cũ ... *@
<div class="modal fade" id="editCartModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold">Chỉnh sửa món</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex mb-3">
                    <img id="editImg" src="" class="rounded border me-3" style="width: 80px; height: 80px; object-fit: cover;">
                    <div>
                        <h6 class="fw-bold mb-1" id="editName">Tên món</h6>
                        <span class="text-success fw-bold" id="editPrice">0 đ</span>
                    </div>
                </div>

                <form id="editCartForm">
                    <input type="hidden" name="cartItemId" id="editCartItemId">

                    <div class="mb-3" id="cartEditSizeSection">
                        <label class="fw-bold small mb-2">Size:</label>
                        <div>
                            <input type="radio" class="btn-check edit-size-radio" name="size" id="editSizeS" value="Nho">
                            <label class="btn btn-outline-secondary btn-sm rounded-pill px-3" for="editSizeS">Nhỏ</label>

                            <input type="radio" class="btn-check edit-size-radio" name="size" id="editSizeM" value="Vua">
                            <label class="btn btn-outline-secondary btn-sm rounded-pill px-3" for="editSizeM">Vừa (+10k)</label>

                            <input type="radio" class="btn-check edit-size-radio" name="size" id="editSizeL" value="Lon">
                            <label class="btn btn-outline-secondary btn-sm rounded-pill px-3" for="editSizeL">Lớn (+20k)</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold small mb-1">Ghi chú:</label>
                        <input type="text" name="note" id="editNote" class="form-control" placeholder="Ghi chú...">
                    </div>

                    <input type="hidden" name="quantity" id="editQuantityHidden">
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-success rounded-pill px-4" onclick="submitEditCart()">Lưu thay đổi</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let editBasePrice = 0;
        const noSizeFoods = ["coca", "trứng chiên", "trứng trần", "trứng ốp la", "bánh flan", "nước suối", "cơm thêm", "cafe đen"];

        function updateQty(itemId, change) {
            var currentQty = parseInt($('#qty-' + itemId).val());
            var newQty = currentQty + change;
            if (newQty < 1) return;

            $.post('/Cart/UpdateQuantityAjax', { cartItemId: itemId, quantity: newQty }, function (res) {
                if (res.success) {
                    $('#qty-' + itemId).val(newQty);
                    $('#total-' + itemId).text(res.itemPrice);
                    $('#cart-total-price').text(res.cartTotal);
                    $('#cartCountBadge').text(res.totalQty);
                }
            });
        }

        function openEditModal(id, name, img, currentPrice, qty, size, note) {
            $('#editCartItemId').val(id);
            $('#editName').text(name);
            $('#editImg').attr('src', img);
            $('#editNote').val(note);
            $('#editQuantityHidden').val(qty);
            $('input[name="size"][value="' + size + '"]').prop('checked', true);

            let priceNum = parseFloat(currentPrice);
            let offset = 0;
            if (size === 'Vua') offset = 10000;
            if (size === 'Lon') offset = 20000;
            editBasePrice = priceNum - offset;

            let lowerName = name.toLowerCase();
            let isNoSize = noSizeFoods.some(keyword => lowerName.includes(keyword));
            if (isNoSize) { $('#cartEditSizeSection').hide(); } else { $('#cartEditSizeSection').show(); }

            updateEditPriceDisplay();
            new bootstrap.Modal(document.getElementById('editCartModal')).show();
        }

        function updateEditPriceDisplay() {
            let selectedSize = $('input[name="size"]:checked').val();
            let finalPrice = editBasePrice;
            if ($('#cartEditSizeSection').is(':visible')) {
                if (selectedSize === 'Vua') finalPrice += 10000;
                if (selectedSize === 'Lon') finalPrice += 20000;
            }
            $('#editPrice').text(new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(finalPrice));
        }

        $('.edit-size-radio').change(function() { updateEditPriceDisplay(); });

        function submitEditCart() {
            $.post('/Cart/UpdateCartItem', $('#editCartForm').serialize(), function(res) {
                if(res.success) { location.reload(); } else { alert('Lỗi cập nhật!'); }
            });
        }
    </script>
}