@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container py-5" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="row justify-content-center w-100">
        <div class="col-md-6 col-lg-5 text-center">
            <div class="card shadow-sm border-0 rounded-4 p-5">

                <img src="~/images/my-success-image.png"
                     alt="Đặt hàng thành công"
                     class="img-fluid mb-4 mx-auto d-block"
                     style="max-height: 250px;">

                <h2 class="fw-bold text-success mb-3" style="color: #10b981 !important;">Đặt hàng thành công!</h2>

                <p class="text-muted mb-4">
                    Cảm ơn bạn đã ủng hộ. Đơn hàng của bạn đang được xử lý và sẽ sớm được giao.
                </p>

                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                    <a asp-controller="Account" asp-action="OrderHistory" class="btn btn-outline-success btn-lg rounded-pill fw-bold px-4 gap-3">
                        <i class="bi bi-clock-history"></i> Xem lịch sử đơn
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-success btn-lg rounded-pill fw-bold px-4" style="background-color: #10b981; border: none;">
                        Tiếp tục mua sắm
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>