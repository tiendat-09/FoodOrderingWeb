@model List<FoodOrderingWeb.Models.Order>
@{
    ViewData["Title"] = "Lịch sử chuyến đi";
    Layout = "~/Views/Shared/_DriverLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-clock-history text-primary me-2"></i> Lịch sử chuyến đi</h4>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Mã Đơn</th>
                        <th>Thời gian</th>
                        <th>Chi tiết chuyến đi</th>
                        <th>Tiền Ship</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-primary">#ORD-@item.OrderId</td>
                                <td class="text-muted small">
                                    @item.OrderDate?.ToString("HH:mm")<br />
                                    @item.OrderDate?.ToString("dd/MM/yyyy")
                                </td>
                                <td>
                                    <div class="fw-bold text-dark"><i class="bi bi-shop text-warning"></i> @(item.Store?.StoreName ?? "N/A")</div>
                                    <div class="small text-muted mt-1"><i class="bi bi-person-fill text-success"></i> Giao đến: @item.ReceiverName</div>
                                </td>
                                <td class="fw-bold text-success">+@item.ShippingFee.ToString("N0") đ</td>
                                <td>
                                    @if (item.Status == "Completed")
                                    {
                                        <span class="badge bg-success">Hoàn thành</span>
                                    }
                                    else if (item.Status == "Cancelled")
                                    {
                                        <span class="badge bg-danger">Đã hủy</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">Đang thực hiện</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-bicycle fs-1 d-block mb-2"></i>
                                Bạn chưa có chuyến đi nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>