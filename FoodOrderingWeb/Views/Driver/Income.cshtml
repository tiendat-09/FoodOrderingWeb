@model List<FoodOrderingWeb.Models.Order>
@{
    ViewData["Title"] = "Ví Thu nhập";
    Layout = "~/Views/Shared/_DriverLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-wallet2 text-success me-2"></i> Ví Thu Nhập</h4>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 bg-success text-white h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0">Hôm nay</h6>
                    <i class="bi bi-calendar-day fs-3 opacity-50"></i>
                </div>
                <h2 class="fw-bold mb-0">@ViewBag.TodayIncome.ToString("N0") <span class="fs-5">đ</span></h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-muted fw-bold mb-0">Tuần này</h6>
                    <i class="bi bi-calendar-week fs-3 text-muted opacity-50"></i>
                </div>
                <h2 class="fw-bold text-dark mb-0">@ViewBag.WeekIncome.ToString("N0") <span class="fs-5 text-muted">đ</span></h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-muted fw-bold mb-0">Tháng này</h6>
                    <i class="bi bi-calendar-month fs-3 text-muted opacity-50"></i>
                </div>
                <h2 class="fw-bold text-dark mb-0">@ViewBag.MonthIncome.ToString("N0") <span class="fs-5 text-muted">đ</span></h2>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <h5 class="fw-bold mb-0">Chi tiết các khoản cộng</h5>
    </div>
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-borderless align-middle">
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var item in Model)
                        {
                            <tr class="border-bottom">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light text-success rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 50px; height: 50px;">
                                            <i class="bi bi-arrow-down-left fs-4"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-1">Thù lao đơn hàng #@item.OrderId</h6>
                                            <small class="text-muted">Giao thành công lúc @(item.DeliveryTime?.ToString("HH:mm dd/MM/yyyy") ?? item.OrderDate?.ToString("HH:mm dd/MM/yyyy"))</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <h5 class="fw-bold text-success mb-0">+@item.ShippingFee.ToString("N0")đ</h5>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center py-4 text-muted">
                                Chưa có phát sinh thu nhập nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>