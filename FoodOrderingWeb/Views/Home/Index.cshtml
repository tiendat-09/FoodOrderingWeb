@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model IEnumerable<FoodOrderingWeb.Models.Food>

@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool isLoggedIn = HttpContextAccessor.HttpContext.Session.GetString("Username") != null;
    var currentRole = HttpContextAccessor.HttpContext.Session.GetString("Role");
}

<div class="container-fluid bg-light py-5 mb-4 text-center" style="background: linear-gradient(135deg, #e0f7fa 0%, #e8f5e9 100%);">
    <h1 class="display-5 fw-bold text-success">OrderFood</h1>
    <p class="lead text-muted">Hôm nay bạn muốn ăn gì?</p>
    <div class="d-flex justify-content-center mt-4">
        <form class="d-flex w-50 shadow-sm" asp-controller="Home" asp-action="Index" method="get">
            <input class="form-control rounded-start border-0 py-3 ps-4" type="search" name="searchString" placeholder="Tìm món ăn..." value="@ViewContext.HttpContext.Request.Query["searchString"]">
            <button class="btn btn-success rounded-end px-4 fw-bold" type="submit"><i class="bi bi-search"></i> Tìm</button>
        </form>
    </div>
</div>

<div class="container pb-5">
    <div class="d-flex align-items-center mb-4 border-start border-4 border-success ps-3">
        <h3 class="fw-bold mb-0 text-success"><i class="bi bi-stars me-2"></i> Món Ngon Gợi Ý</h3>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5"><p class="text-muted">Không tìm thấy món ăn nào.</p></div>
    }
    else
    {
        <div class="row row-cols-2 row-cols-md-5 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm card-hover">
                        <div class="position-relative">
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.FoodName" style="height: 160px; object-fit: cover;" onerror="this.src='/images/foods/default.jpg'">
                            <span class="position-absolute bottom-0 start-0 bg-white text-success fw-bold px-2 py-1 m-2 rounded shadow-sm small">@item.Price.ToString("N0") đ</span>
                        </div>
                        <div class="card-body p-3 d-flex flex-column">
                            <h6 class="card-title fw-bold text-truncate" title="@item.FoodName">@item.FoodName</h6>
                            <p class="card-text small text-muted mb-2 text-truncate"><i class="bi bi-shop me-1"></i> @(item.Store?.StoreName ?? "Quán ăn")</p>
                            <div class="mt-auto">
                                @if (currentRole != "Driver" && currentRole != "StoreOwner")
                                {
                                    <button onclick="openFoodDetail(@item.FoodId)" class="btn btn-outline-success btn-sm w-100 rounded-pill"><i class="bi bi-cart-plus"></i> Thêm</button>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted w-100 py-2 border">Chế độ đối tác</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="foodDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg overflow-hidden">
            <div class="row g-0">
                <div class="col-md-6">
                    <img id="detailImage" src="" class="img-fluid w-100 h-100" style="object-fit: cover; aspect-ratio: 1/1;" onerror="this.src='/images/foods/default.jpg'">
                </div>
                <div class="col-md-6 d-flex flex-column">
                    <div class="modal-header border-0 pb-0"><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                    <div class="modal-body pt-0 px-4">
                        <h3 class="fw-bold mb-1" id="detailName">Tên món</h3>
                        <p class="text-success fw-bold fs-4 mb-3" id="detailPrice">0 đ</p>
                        <p class="text-muted" id="detailDesc">Mô tả...</p>
                        <hr class="opacity-25">
                        <div class="mb-3" id="modalSizeSection">
                            <label class="fw-bold small mb-2">Chọn Size:</label>
                            <div>
                                <input type="radio" class="btn-check" name="detailSize" id="sizeS" value="Nho" checked><label class="btn btn-outline-secondary btn-sm rounded-pill px-3 me-2" for="sizeS">Nhỏ</label>
                                <input type="radio" class="btn-check" name="detailSize" id="sizeM" value="Vua"><label class="btn btn-outline-secondary btn-sm rounded-pill px-3 me-2" for="sizeM">Vừa (+10k)</label>
                                <input type="radio" class="btn-check" name="detailSize" id="sizeL" value="Lon"><label class="btn btn-outline-secondary btn-sm rounded-pill px-3" for="sizeL">Lớn (+20k)</label>
                            </div>
                        </div>
                        <div class="mb-4"><label class="fw-bold small mb-1">Ghi chú:</label><textarea id="detailNote" class="form-control" rows="2" placeholder="Ví dụ: Không hành, ít đá..."></textarea></div>
                        <div class="mt-auto d-flex align-items-center gap-3 mb-4">
                            <div class="input-group" style="width: 130px;">
                                <button class="btn btn-outline-secondary" onclick="changeDetailQty(-1)">-</button>
                                <input type="text" id="detailQty" class="form-control text-center fw-bold" value="1" readonly>
                                <button class="btn btn-outline-secondary" onclick="changeDetailQty(1)">+</button>
                            </div>
                            <button class="btn btn-success fw-bold rounded-pill flex-grow-1 py-2" onclick="addFromModal(@isLoggedIn.ToString().ToLower())"><i class="bi bi-cart-plus me-2"></i> Thêm - <span id="detailTotalPrice">0 đ</span></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="conflictModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body text-center p-4">
                <div class="mb-3"><div class="rounded-circle bg-warning bg-opacity-10 d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;"><i class="bi bi-exclamation-triangle-fill text-warning display-4"></i></div></div>
                <h5 class="fw-bold mb-2">Bắt đầu giỏ hàng mới?</h5>
                <p class="text-muted mb-4" id="conflictMessage">Giỏ hàng đang có món từ quán khác. Bạn có muốn xóa giỏ cũ để đặt món tại quán này không?</p>
                <div class="d-flex gap-2 justify-content-center">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="button" class="btn btn-success rounded-pill px-4 fw-bold" onclick="confirmStartNewCart()">Đồng ý tạo mới</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="requireLoginModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-success text-white"><h5 class="modal-title fw-bold">Yêu cầu đăng nhập</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <div class="modal-body text-center py-4">
                <div class="mb-3"><i class="bi bi-cart-x text-warning" style="font-size: 3rem;"></i></div>
                <h5 class="fw-bold">Bạn chưa đăng nhập!</h5>
                <p class="text-muted">Vui lòng đăng nhập để thêm món vào giỏ hàng.</p>
                <div class="mt-4"><a href="/Account/Login" class="btn btn-success rounded-pill px-4 fw-bold">Đăng nhập ngay</a></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentFoodId = 0;
        let basePrice = 0;
        const noSizeFoods = ["coca", "trứng chiên", "trứng trần", "trứng ốp la", "bánh flan", "nước suối", "cơm thêm", "cafe đen"];
        let pendingCartItem = null;

        function openFoodDetail(id) {
            currentFoodId = id;
            $('#detailQty').val(1); $('#detailNote').val(''); $('#sizeS').prop('checked', true);
            $.get('/Home/GetFoodInfo?id=' + id, function(res) {
                if(res.success) {
                    basePrice = res.data.price;
                    let foodName = res.data.name;
                    $('#detailName').text(foodName);
                    $('#detailDesc').text(res.data.description);
                    $('#detailImage').attr('src', res.data.image);
                    let isNoSize = noSizeFoods.some(keyword => foodName.toLowerCase().includes(keyword));
                    if (isNoSize) { $('#modalSizeSection').hide(); } else { $('#modalSizeSection').show(); }
                    updatePriceDisplay();
                    new bootstrap.Modal(document.getElementById('foodDetailModal')).show();
                }
            });
        }

        function updatePriceDisplay() {
            let size = $('input[name="detailSize"]:checked').val();
            let qty = parseInt($('#detailQty').val());
            let unitPrice = basePrice;
            if ($('#modalSizeSection').is(':visible')) {
                if (size === 'Vua') unitPrice += 10000;
                if (size === 'Lon') unitPrice += 20000;
            }
            $('#detailPrice').text(new Intl.NumberFormat('vi-VN').format(unitPrice) + " đ");
            $('#detailTotalPrice').text(new Intl.NumberFormat('vi-VN').format(unitPrice * qty) + " đ");
        }

        $('input[name="detailSize"]').change(function() { updatePriceDisplay(); });

        function changeDetailQty(change) {
            let q = parseInt($('#detailQty').val()) + change;
            if(q >= 1) { $('#detailQty').val(q); updatePriceDisplay(); }
        }

        function addFromModal(isLoggedIn) {
            if (!isLoggedIn) {
                bootstrap.Modal.getInstance(document.getElementById('foodDetailModal')).hide();
                new bootstrap.Modal(document.getElementById('requireLoginModal')).show();
                return;
            }
            let qty = parseInt($('#detailQty').val());
            let size = $('#modalSizeSection').is(':visible') ? $('input[name="detailSize"]:checked').val() : 'Nho';
            let note = $('#detailNote').val();

            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { foodId: currentFoodId, quantity: qty, size: size, note: note },
                success: function(res) {
                    if (res.success) {
                        if(typeof showGlobalNotification === 'function') showGlobalNotification(res.message, 'success');
                        $('#cartCountBadge').text(res.totalQty);
                        bootstrap.Modal.getInstance(document.getElementById('foodDetailModal')).hide();
                    } else if (res.conflict) {
                        pendingCartItem = { foodId: currentFoodId, quantity: qty, size: size, note: note };
                        $('#conflictMessage').text(res.message);
                        bootstrap.Modal.getInstance(document.getElementById('foodDetailModal')).hide();
                        new bootstrap.Modal(document.getElementById('conflictModal')).show();
                    } else {
                        alert(res.message);
                    }
                }
            });
        }

        function confirmStartNewCart() {
            if (!pendingCartItem) return;
            $.ajax({
                url: '/Cart/ClearAndAddToCart',
                type: 'POST',
                data: pendingCartItem,
                success: function(res) {
                    if(res.success) {
                        if(typeof showGlobalNotification === 'function') showGlobalNotification(res.message, 'success');
                        $('#cartCountBadge').text(res.totalQty);
                        bootstrap.Modal.getInstance(document.getElementById('conflictModal')).hide();
                    }
                }
            });
        }
    </script>
}