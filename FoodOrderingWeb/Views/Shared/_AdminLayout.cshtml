@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị hệ thống</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            background-color: #f3f4f6;
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
        }

        .sidebar {
            width: 260px;
            min-height: 100vh;
            background: #fff;
            position: fixed;
            box-shadow: 2px 0 10px rgba(0,0,0,0.05);
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }

        .sidebar-logo {
            padding: 25px;
            font-weight: bold;
            font-size: 1.5rem;
            color: #00b074;
            border-bottom: 1px solid #f0f0f0;
            text-align: center;
        }

        .nav-link {
            color: #555;
            font-weight: 500;
            padding: 12px 25px;
            transition: 0.3s;
            border-radius: 0 25px 25px 0;
            margin-right: 15px;
        }

            .nav-link:hover {
                background: #f8f9fa;
                color: #00b074;
                padding-left: 30px;
            }

            .nav-link.active {
                background: linear-gradient(90deg, #00b09b 0%, #96c93d 100%);
                color: white !important;
                box-shadow: 0 4px 10px rgba(0, 176, 155, 0.3);
            }

            .nav-link i {
                margin-right: 15px;
                font-size: 1.1rem;
            }

        /* 🔥 CSS thêm màu cho Icon */
        .c-overview {
            color: #2ecc71;
        }
        /* Xanh lá */
        .c-users {
            color: #3498db;
        }
        /* Xanh dương */
        .c-stores {
            color: #f39c12;
        }
        /* Cam */
        .c-orders {
            color: #9b59b6;
        }
        /* Tím */
        .c-profile {
            color: #1abc9c;
        }
        /* Xanh ngọc */

        /* Khi thẻ được chọn (active) thì icon tự động chuyển về màu trắng */
        .nav-link.active i {
            color: white !important;
        }

        .main-content {
            margin-left: 260px;
            padding: 30px;
        }

        .top-navbar {
            height: 70px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 30px;
            border-radius: 15px;
            margin-bottom: 30px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-logo">
            <i class="bi bi-shield-lock-fill"></i> ADMIN 
        </div>
        <ul class="nav flex-column mt-4">
            <li class="nav-item">
                <a href="/Admin" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")">
                    <i class="bi bi-speedometer2 c-overview"></i> Tổng quan
                </a>
            </li>
            <li class="nav-item">
                <a href="/Admin/Users" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Users" ? "active" : "")">
                    <i class="bi bi-people-fill c-users"></i> Người dùng
                </a>
            </li>
            <li class="nav-item">
                <a href="/Admin/ManageStores" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "ManageStores" ? "active" : "")">
                    <i class="bi bi-shop c-stores"></i> Cửa hàng
                </a>
            </li>

            <li class="mt-4 mb-2 px-4 border-top"></li>

            <li class="nav-item">
                <a href="/Admin/Profile" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Profile" ? "active" : "")">
                    <i class="bi bi-person-circle c-profile"></i> Hồ sơ cá nhân
                </a>
            </li>
            <li class="nav-item mb-4">
                <a href="/Account/Logout" class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                </a>
            </li>
        </ul>
    </div>

    <div class="main-content">
        <div class="top-navbar">
            <div class="d-flex align-items-center text-secondary fw-bold" style="font-size: 1.1rem;">
                <i class="bi bi-clock-history me-2 text-primary"></i>
                <span id="liveSystemClock">Đang tải dữ liệu...</span>
            </div>
        </div>

        @* Hiển thị thông báo bằng SweetAlert2 *@
        @if (TempData["Success"] != null)
        {
            <script>Swal.fire({ icon: 'success', title: 'Thành công!', text: '@TempData["Success"]', timer: 2000, showConfirmButton: false });</script>
        }
        @if (TempData["Error"] != null)
        {
            <script>Swal.fire({ icon: 'error', title: 'Lỗi!', text: '@TempData["Error"]' });</script>
        }

        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
<script>
    // 1. Tách logic đồng hồ ra thành 1 hàm riêng
    function updateClock() {
        let d = new Date();
        $('#liveSystemClock').text(d.toLocaleDateString('vi-VN') + ' | ' + d.toLocaleTimeString('vi-VN'));
    }

    // 2. Gọi hàm chạy NGAY LẬP TỨC ở 0ms đầu tiên (hết bị hiện chữ Đang tải)
    updateClock();

    // 3. Sau đó mới cho nó lặp lại mỗi 1 giây
    setInterval(updateClock, 1000);
</script>
</html>