<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Đối tác Tài xế</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f4f6f9;
        }

        .header {
            background: white;
            padding: 15px 30px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 24px;
            font-weight: bold;
            color: #fd7e14; /* MÀU CAM CỦA TÀI XẾ */
            text-decoration: none;
        }

        .main-wrapper {
            display: flex;
            min-height: calc(100vh - 70px);
        }

        .sidebar {
            width: 260px;
            background: white;
            padding: 20px 0;
            box-shadow: 2px 0 5px rgba(0,0,0,0.05);
        }

        .menu-item {
            padding: 12px 30px;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #5a6c7d;
            text-decoration: none;
        }

            .menu-item:hover {
                background: #fff4ec;
                color: #fd7e14;
            }

            .menu-item.active {
                background: #ffe8d6;
                color: #fd7e14;
                font-weight: 600;
                border-right: 4px solid #fd7e14;
            }

        .main-content {
            flex: 1;
            padding: 30px;
            overflow-y: auto;
            background: #f4f6f9;
        }
    </style>
</head>
<body>
    <div class="header">
        <a href="/Driver" class="logo">
            <span>🛵</span>
            <span>Kênh Tài Xế</span>
        </a>
        <a href="/" class="btn btn-outline-secondary rounded-pill px-4 fw-bold shadow-sm">
            <i class="bi bi-house-door me-1"></i> Về trang chủ
        </a>
    </div>

    <div class="main-wrapper">
        <div class="sidebar">
            <a href="/Driver" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")">
                <span style="font-size: 20px;">📦</span> <span>Đơn hàng</span>
            </a>
            <a href="/Driver/History" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "History" ? "active" : "")">
                <span style="font-size: 20px;">🕒</span> <span>Lịch sử chuyến đi</span>
            </a>
            <a href="/Driver/Income" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "Income" ? "active" : "")">
                <span style="font-size: 20px;">💵</span> <span>Thu nhập</span>
            </a>
            <a href="/Driver/Reviews" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "Reviews" ? "active" : "")">
                <span style="font-size: 20px;">⭐</span> <span>Đánh giá</span>
            </a>
            <a href="/Driver/Profile" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "Profile" ? "active" : "")">
                <span style="font-size: 20px;">👤</span> <span>Hồ sơ cá nhân</span>
            </a>
            <div style="border-top: 1px solid #eee; margin: 10px 20px;"></div>
            <a href="/Account/Logout" class="menu-item text-danger fw-bold">
                <span style="font-size: 20px;">🚪</span> <span>Đăng xuất</span>
            </a>
        </div>

        <div class="main-content">
            @RenderBody()
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>