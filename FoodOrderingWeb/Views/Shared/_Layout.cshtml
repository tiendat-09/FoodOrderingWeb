@using Microsoft.AspNetCore.Http
@using FoodOrderingWeb.Models
@using FoodOrderingWeb.Helpers
@inject IHttpContextAccessor HttpContextAccessor
@inject FoodOrderingDbContext _context

@{
    Layout = null;
    var username = HttpContextAccessor.HttpContext.Session.GetString("Username");
    var fullName = HttpContextAccessor.HttpContext.Session.GetString("FullName");
    var role = HttpContextAccessor.HttpContext.Session.GetString("Role") ?? "";
    var userId = HttpContextAccessor.HttpContext.Session.GetInt32("UserId");
    bool hasStore = false;

    if (userId != null)
    {
        var dbUser = _context.Users.Find(userId);
        if (dbUser != null) { role = dbUser.Role; }
        hasStore = _context.Stores.Any(s => s.OwnerId == userId);
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OrderFood</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #fcfcfc;
            font-family: 'Segoe UI', sans-serif;
        }

        .header {
            background: white;
            padding: 15px 30px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
            transition: top 0.3s ease;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 24px;
            font-weight: bold;
            color: #00b074 !important;
            text-decoration: none;
        }

        .hamburger-toggle {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            width: 22px;
            height: 16px;
            background: none;
            border: none;
            padding: 0;
            cursor: pointer;
            margin-left: 15px;
        }

            .hamburger-toggle span {
                display: block;
                height: 2.5px;
                width: 100%;
                background-color: #444;
                border-radius: 2px;
                transition: 0.3s;
            }

            .hamburger-toggle:hover span {
                background-color: #00b074;
            }

        .dropdown-menu {
            border: none;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
            border-radius: 12px;
            padding: 10px 0;
            margin-top: 20px !important;
        }

        .dropdown-item {
            padding: 10px 20px;
            font-size: 14px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .dropdown-item:hover:not(.disabled) {
                background-color: #f8f9fa;
                color: #00b074;
            }

        #nav-notification {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            min-width: 320px;
            display: none;
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            border-radius: 30px;
        }

        .welcome-center {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            font-weight: 600;
            font-size: 16px;
            color: #5a6c7d;
        }
    </style>
</head>
<body>
    <div id="global-live-banner" class="bg-warning text-dark text-center py-2 fw-bold shadow-sm" style="display: none; font-size: 0.95rem; cursor: pointer; position: sticky; top: 0; z-index: 1050;" onclick="window.location.href='/Account/OrderHistory'">
        <div class="container d-flex justify-content-center align-items-center gap-2">
            <span class="spinner-grow spinner-grow-sm text-danger" role="status"></span>
            <span id="global-live-text"></span>
            <i class="bi bi-chevron-right ms-2 small"></i>
        </div>
    </div>

    <div id="nav-notification" class="alert text-center fw-bold border-0 py-3 px-4" role="alert">
        <i class="me-2 fs-5" id="nav-notification-icon"></i> <span id="nav-notification-msg">Thông báo</span>
    </div>

    <div class="header">
        <a href="/" class="logo"><i class="bi bi-basket2-fill"></i> OrderFood</a>

        @if (!string.IsNullOrEmpty(fullName))
        {
            <div class="welcome-center d-none d-md-block">👋 Xin chào, <span style="color: #00b074;">@fullName</span></div>
        }

        <div class="d-flex align-items-center">
            <a href="/" class="nav-link text-dark fw-bold me-4 d-none d-md-block" style="font-size: 16px;">Trang chủ</a>

            @{
                var sessionCart = HttpContextAccessor.HttpContext.Session.Get<List<FoodOrderingWeb.Models.CartItem>>("Cart");
                int cartCount = sessionCart != null ? sessionCart.Sum(x => x.Quantity) : 0;
            }
            <a href="/Cart" class="position-relative text-dark text-decoration-none" style="margin-right: 15px;">
                <i class="bi bi-cart3" style="font-size: 1.6rem;"></i>
                <span id="cartCountBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 10px;">@cartCount</span>
            </a>

            @if (!string.IsNullOrEmpty(username))
            {
                <div class="dropdown">
                    <button class="hamburger-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <span></span><span></span><span></span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                        <li><a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person-circle text-secondary"></i> Hồ sơ cá nhân</a></li>

                        @if (role != "Admin" && role != "StoreOwner" && role != "Driver")
                        {
                            <li><a class="dropdown-item" href="/Account/OrderHistory"><i class="bi bi-clock-history text-secondary"></i> Lịch sử đơn mua</a></li>
                        }

                        <li><hr class="dropdown-divider"></li>

                        @if (role == "Driver")
                        {
                            <li><a class="dropdown-item text-primary fw-bold" href="/Driver"><i class="bi bi-bicycle"></i> Kênh Tài Xế</a></li>
                        }
                        else if (role == "StoreOwner")
                        {
                            <li><a class="dropdown-item fw-bold" style="color: #f39c12 !important;" href="/StoreManager"><i class="bi bi-shop"></i> Kênh Người Bán</a></li>
                        }
                        else if (role == "Admin")
                        {
                            <li><a class="dropdown-item text-danger fw-bold" href="/Admin"><i class="bi bi-shield-lock"></i> Trang Quản trị</a></li>
                        }

                        @if (role != "Admin" && role != "StoreOwner" && role != "Driver")
                        {
                            if (role == "PendingDriver")
                            {
                                <li><a class="dropdown-item text-secondary disabled"><i class="bi bi-hourglass-split"></i> Đang duyệt Tài xế...</a></li>
                            }
                            else if (role != "PendingStoreOwner")
                            {
                                <li><a class="dropdown-item text-primary" href="javascript:void(0)" onclick="checkRegistration('driver')"><i class="bi bi-bicycle"></i> Đăng ký Tài Xế</a></li>
                            }

                            if (hasStore && role != "PendingStoreOwner")
                            {
                                <li><a class="dropdown-item text-danger disabled"><i class="bi bi-lock-fill"></i> Quán đang bị khóa</a></li>
                            }
                            else if (role == "PendingStoreOwner")
                            {
                                <li><a class="dropdown-item text-secondary disabled"><i class="bi bi-hourglass-split"></i> Đang duyệt Quán...</a></li>
                            }
                            else if (role != "PendingDriver")
                            {
                                <li><a class="dropdown-item text-warning" style="color: #f39c12 !important;" href="javascript:void(0)" onclick="checkRegistration('store')"><i class="bi bi-shop-window"></i> Đăng ký Chủ Quán</a></li>
                            }
                        }

                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="/Account/Logout"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a></li>
                    </ul>
                </div>
            }
            else
            {
                <a href="/Account/Login" class="btn btn-outline-success btn-sm rounded-pill px-4 fw-bold ms-3">Đăng nhập</a>
                <a href="/Account/Register" class="btn btn-success btn-sm rounded-pill px-4 fw-bold ms-2 text-white">Đăng ký</a>
            }
        </div>
    </div>

    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function showGlobalNotification(message, type = 'success') {
            var alertBox = $('#nav-notification');
            var icon = $('#nav-notification-icon');
            var msgSpan = $('#nav-notification-msg');

            alertBox.removeClass('alert-success alert-danger alert-info text-success text-danger text-info');
            icon.removeClass('bi-check-circle-fill bi-exclamation-triangle-fill bi-info-circle-fill');

            if (type === true || type === 'success') {
                alertBox.addClass('alert-success text-success');
                icon.addClass('bi-check-circle-fill');
            } else if (type === false || type === 'danger' || type === 'error') {
                alertBox.addClass('alert-danger text-danger');
                icon.addClass('bi-exclamation-triangle-fill');
            } else if (type === 'info') {
                alertBox.addClass('alert-info text-info');
                icon.addClass('bi-info-circle-fill');
            }

            msgSpan.text(message);
            alertBox.stop(true, true).fadeIn().delay(3500).fadeOut();
        }

        $(document).ready(function() {

        @if (TempData["GlobalMessage"] != null)
        {
            var isSuccess = TempData["GlobalType"]?.ToString() == "success" ? "true" : "false";
            <text>setTimeout(function() { showGlobalNotification('@Html.Raw(TempData["GlobalMessage"])', @isSuccess); }, 600);</text>
        }
        else if (TempData["SuccessMessage"] != null)
        {
            <text>setTimeout(function() { showGlobalNotification('@Html.Raw(TempData["SuccessMessage"])', 'success'); }, 600);</text>
        }
        else if (TempData["Error"] != null)
        {
            <text>setTimeout(function() { showGlobalNotification('@Html.Raw(TempData["Error"])', 'error'); }, 600);</text>
        }

            var userRole = "@role";
            var path = window.location.pathname;
            if (path === "/" || path === "/Home" || path === "/Home/Index" || path === "") {
                if (userRole === "Driver" || userRole === "StoreOwner") {
                    setTimeout(function() {
                        showGlobalNotification('Chế độ đối tác: Dùng tài khoản Khách hàng để mua sắm!', 'info');
                    }, 500);
                }
            }

            if (userRole === "PendingDriver" || userRole === "PendingStoreOwner") {
                function checkUserAccountStatus() {
                    $.get('/Account/CheckUserStatus', function(res) {
                        if (res) {
                            if (res.hasRejection) {
                                Swal.fire({
                                    title: 'Hồ sơ bị từ chối!', text: `Lý do: ${res.reason}`, icon: 'error',
                                    confirmButtonText: 'Đã hiểu', confirmButtonColor: '#d33', allowOutsideClick: false
                                }).then(() => { window.location.reload(); });
                            } else if (res.isApproved) {
                                Swal.fire({
                                    title: 'Xin chúc mừng!', text: 'Hồ sơ của bạn đã được Admin phê duyệt thành công!', icon: 'success',
                                    confirmButtonText: 'Bắt đầu ngay', confirmButtonColor: '#00b074', allowOutsideClick: false
                                }).then(() => { window.location.reload(); });
                            }
                        }
                    });
                }
                setInterval(checkUserAccountStatus, 5000);
            }

            if (userRole === "Customer" || userRole === "PendingDriver" || userRole === "PendingStoreOwner" || userRole === "") {
                function checkLiveBanner() {
                    $.get('/Cart/GetLiveOrderBanner', function(res) {
                        if (res && res.hasOrder) {
                            $('#global-live-text').html('Đơn hàng <strong>#' + res.orderId + '</strong>: ' + res.message);
                            $('#global-live-banner').slideDown(300);
                            $('.header').css('top', $('#global-live-banner').outerHeight() + 'px');
                        } else {
                            $('#global-live-banner').slideUp(300);
                            $('.header').css('top', '0');
                        }
                    });
                }
                checkLiveBanner(); setInterval(checkLiveBanner, 5000);
            }
        });

        function checkRegistration(type) {
            $.ajax({
                url: '/Account/CheckRegistration', type: 'GET', data: { type: type },
                success: function (res) {
                    if (res.allowed) {
                        window.location.href = type === 'store' ? '/Account/RegisterStore' : '/Account/RegisterDriver';
                    } else {
                        Swal.fire('Thông báo', res.message, 'warning');
                    }
                },
                error: function () { Swal.fire('Lỗi', 'Không kết nối được với máy chủ', 'error'); }
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                Swal.fire({
                    icon: 'error', title: 'Truy cập bị từ chối!',
                    text: '@Html.Raw(TempData["ErrorMessage"])',
                    confirmButtonColor: '#dc3545', confirmButtonText: 'Đã hiểu'
                });
            });
        </script>
    }
</body>
</html>