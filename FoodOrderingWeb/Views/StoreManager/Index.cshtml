@model List<FoodOrderingWeb.Models.Order>
@{
    ViewData["Title"] = "Tổng quan & Doanh thu";
    Layout = "~/Views/Shared/_StoreLayout.cshtml";
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white shadow-sm border-0 rounded-4 position-relative overflow-hidden h-100">
            <div class="card-body p-3">
                <h6 class="fw-bold opacity-75 mb-1" style="font-size: 0.8rem;">TỔNG ĐƠN HÀNG</h6>
                <h3 class="fw-bold mb-0">@(ViewBag.TotalOrders ?? Model.Count)</h3>
                <i class="bi bi-box-seam position-absolute" style="font-size: 4rem; right: -5px; bottom: -15px; opacity: 0.2;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white shadow-sm border-0 rounded-4 position-relative overflow-hidden h-100" style="background: #17a2b8;">
            <div class="card-body p-3">
                <h6 class="fw-bold opacity-75 mb-1" style="font-size: 0.8rem;">DOANH THU HÔM NAY</h6>
                <h3 class="fw-bold mb-0">@((ViewBag.TodayRevenue ?? 0).ToString("N0")) đ</h3>
                <i class="bi bi-calendar-day position-absolute" style="font-size: 4rem; right: -5px; bottom: -15px; opacity: 0.2;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white shadow-sm border-0 rounded-4 position-relative overflow-hidden h-100">
            <div class="card-body p-3">
                <h6 class="fw-bold opacity-75 mb-1" style="font-size: 0.8rem;">DOANH THU THÁNG NÀY</h6>
                <h3 class="fw-bold mb-0">@((ViewBag.MonthRevenue ?? 0).ToString("N0")) đ</h3>
                <i class="bi bi-calendar-check position-absolute" style="font-size: 4rem; right: -5px; bottom: -15px; opacity: 0.2;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white shadow-sm border-0 rounded-4 position-relative overflow-hidden h-100" style="background: #e67e22;">
            <div class="card-body p-3">
                <h6 class="fw-bold opacity-75 mb-1" style="font-size: 0.8rem;">TỔNG DOANH THU LŨY KẾ</h6>
                <h3 class="fw-bold mb-0">@((ViewBag.TotalRevenue ?? 0).ToString("N0")) đ</h3>
                <i class="bi bi-cash-stack position-absolute" style="font-size: 4rem; right: -5px; bottom: -15px; opacity: 0.2;"></i>
            </div>
        </div>
    </div>
</div>

<div class="card-custom border-0 shadow-sm p-4 rounded-4 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-list-ul me-2"></i> Đơn hàng gần đây</h5>
        <button class="btn btn-outline-success btn-sm rounded-pill fw-bold" onclick="location.reload()">
            <i class="bi bi-arrow-clockwise"></i> Làm mới
        </button>
    </div>

    <div class="table-responsive" id="storeOrderContainer">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>Thời gian</th>
                    <th>Tài xế</th>
                    <th>Tiền đơn</th>
                    <th class="text-center">Chi tiết</th>
                    <th class="text-center" style="min-width: 150px;">Trạng thái / Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    string s = (item.Status ?? "").ToLower();
                    <tr>
                        <td class="fw-bold text-primary">#@item.OrderId</td>
                        <td>@item.ReceiverName</td>
                        <td>@(item.OrderDate?.ToString("HH:mm dd/MM"))</td>
                        <td>
                            @if (item.DriverId != null && item.Driver != null)
                            {
                                <div class="fw-bold text-primary"><i class="bi bi-bicycle"></i> @item.Driver.FullName</div>
                                <small class="text-muted"><i class="bi bi-telephone"></i> @item.Driver.PhoneNumber</small>
                            }
                            else if (s == "cancelled" || s.Contains("từ chối"))
                            {
                                <span class="text-danger small fw-bold"><i class="bi bi-x-circle"></i> Đã hủy</span>
                            }
                            else if (s == "pending" || s == "chờ xử lý")
                            {
                                <span class="text-warning small fw-bold"><i class="bi bi-hourglass-split"></i> Chờ duyệt</span>
                            }
                            else
                            {
                                <span class="text-info small fw-bold">
                                    <span class="spinner-grow spinner-grow-sm"></span> Đang gọi Shipper...
                                </span>
                            }
                        </td>
                        <td class="fw-bold text-danger">@item.TotalAmount.ToString("N0")đ</td>

                        <td class="text-center">
                            <button class="btn btn-sm btn-info text-white rounded-circle shadow-sm" onclick="viewOrderDetails(@item.OrderId)" title="Xem chi tiết món" style="width: 35px; height: 35px;">
                                <i class="bi bi-eye-fill fs-6"></i>
                            </button>
                        </td>

                        <td class="text-center">
                            @if (s == "pending")
                            {
                                <button class="btn btn-sm btn-success rounded-circle shadow-sm me-2" onclick="acceptOrder(@item.OrderId)" title="Nhận đơn này" style="width: 35px; height: 35px;">
                                    <i class="bi bi-check-lg fs-6"></i>
                                </button>
                                <button class="btn btn-sm btn-danger rounded-circle shadow-sm" onclick="rejectOrder(@item.OrderId)" title="Từ chối đơn" style="width: 35px; height: 35px;">
                                    <i class="bi bi-x-lg fs-6"></i>
                                </button>
                            }
                            else if (s == "cancelled")
                            {
                                bool isUserCancel = !string.IsNullOrEmpty(item.CancelReason) && item.CancelReason.StartsWith("Khách hủy");
                                string cancelText = isUserCancel ? "Khách tự hủy" : "Quán từ chối";
                                string cleanReason = item.CancelReason?.Replace("Khách hủy: ", "").Replace("Quán hủy: ", "").Trim();

                                <div class="d-flex flex-column align-items-center">
                                    <span class="badge bg-danger px-3 py-1 rounded-pill mb-1">@cancelText</span>

                                    @if (!string.IsNullOrEmpty(cleanReason))
                                    {
                                        <span class="small text-muted mb-1 fst-italic" style="max-width: 150px; word-wrap: break-word; font-size: 0.8rem;">(@cleanReason)</span>
                                    }

                                    @{
                                        var pm = (item.PaymentMethod ?? "").ToLower();
                                    }
                                    @if (pm.Contains("qr") || pm.Contains("vnpay") || pm.Contains("chuyển khoản"))
                                    {
                                        <span class="badge" style="background-color: #fff3cd; color: #856404; border: 1px solid #ffeeba; font-size: 0.75rem;">
                                            <i class="bi bi-arrow-counterclockwise"></i> Hoàn: <b>@item.TotalAmount.ToString("N0")đ</b>
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                string statusVN = s switch
                                {
                                    "preparing" => "Đang nấu",
                                    "shipping" => "Tài xế đang đến",
                                    "arrived" => "Chờ lấy món",
                                    "delivering" => "Đang giao",
                                    "completed" => "Thành công",
                                    _ => item.Status
                                };
                                string bClass = s == "completed" ? "bg-success" : (s == "arrived" ? "bg-dark" : "bg-primary");
                                <span class="badge @bClass px-3 py-2 rounded-pill">@statusVN</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Hàm xem chi tiết đơn hàng bằng SweetAlert2
        function viewOrderDetails(id) {
            $.get('/StoreManager/GetOrderDetails', { orderId: id }, function(res) {
                if(res.success) {
                    let htmlContent = '<ul class="list-group text-start shadow-sm rounded-3 mt-3">';

                    res.data.forEach(item => {
                        let noteHTML = item.note ? `<div class="text-danger mt-1" style="font-size: 0.85rem;"><i class="bi bi-exclamation-circle-fill"></i> Ghi chú: ${item.note}</div>` : '';

                        htmlContent += `
                        <li class="list-group-item d-flex justify-content-between align-items-center p-3 border-0 border-bottom">
                            <div class="d-flex align-items-center">
                                <img src="${item.imageUrl}" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px; margin-right: 15px; border: 1px solid #ddd;">
                                <div>
                                    <h6 class="mb-0 fw-bold text-dark">${item.foodName}</h6>
                                    <div class="text-muted small">${item.price.toLocaleString('vi-VN')} đ</div>
                                    ${noteHTML}
                                </div>
                            </div>
                            <span class="badge bg-primary rounded-pill px-3 py-2 fs-6">x ${item.quantity}</span>
                        </li>`;
                    });
                    htmlContent += '</ul>';

                    Swal.fire({
                        title: `<h4 class="fw-bold text-primary mb-0"><i class="bi bi-receipt"></i> Chi tiết đơn #${id}</h4>`,
                        html: htmlContent,
                        width: '550px',
                        showCloseButton: true,
                        showConfirmButton: true,
                        confirmButtonText: 'Đóng',
                        confirmButtonColor: '#6c757d'
                    });
                } else {
                    Swal.fire('Lỗi', res.message, 'error');
                }
            });
        }

        // Hàm Nhận đơn
        function acceptOrder(id) {
            $.post('/StoreManager/AcceptOrder', { orderId: id }, function(res) {
                if(res.success) { showGlobalNotification('Đã nhận đơn hàng!', 'success'); loadTable(); }
                else { Swal.fire('Lỗi', res.message, 'error'); }
            });
        }

        // Hàm Từ chối đơn
        function rejectOrder(id) {
            Swal.fire({
                title: 'Lý do từ chối', input: 'text', inputPlaceholder: 'Ví dụ: Đã hết món...',
                showCancelButton: true, confirmButtonText: 'Từ chối', confirmButtonColor: '#dc3545'
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    $.post('/StoreManager/RejectOrder', { orderId: id, cancelReason: result.value }, function(res) {
                        if(res.success) { showGlobalNotification('Đã từ chối đơn hàng!', 'success'); loadTable(); }
                    });
                }
            });
        }

        function loadTable() {
            $('#storeOrderContainer').load(location.href + ' #storeOrderContainer > *');
        }

        // Tự động tải lại ngầm mỗi 4 giây
        $(document).ready(function () {
            let currentOrderCount = $('.table tbody tr').length;
            setInterval(function () {
                $('#storeOrderContainer').load(location.href + ' #storeOrderContainer > *', function() {
                    let newOrderCount = $('.table tbody tr').length;
                    if (newOrderCount > currentOrderCount) {
                        if (typeof showGlobalNotification === 'function') showGlobalNotification('Có đơn hàng mới!', 'success');
                        currentOrderCount = newOrderCount;
                    }
                });
            }, 4000);
        });
    </script>
}